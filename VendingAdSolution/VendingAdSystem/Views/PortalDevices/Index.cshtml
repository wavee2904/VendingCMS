@model List<Device>
@{
    var totalDevices = ViewBag.TotalDevices;
    var onlineCount = ViewBag.OnlineCount;
    var offlineCount = ViewBag.OfflineCount;
    var currentByDevice = ViewBag.CurrentScheduleByDevice as Dictionary<int, PlaybackSchedule> ?? new Dictionary<int, PlaybackSchedule>();
    var upcomingByDevice = ViewBag.UpcomingScheduleByDevice as Dictionary<int, PlaybackSchedule> ?? new Dictionary<int, PlaybackSchedule>();
    var utcNow = ViewBag.UtcNow as DateTime? ?? DateTime.UtcNow;
    var vietnamNow = ViewBag.VietnamNow as DateTime? ?? DateTime.UtcNow;
    ViewData["Title"] = "Devices";

    string VietnamDate(DateTime utcDate) => utcDate.AddHours(7).ToString("yyyy-MM-dd");
}

<div class="page-header">
  <h1 class="page-title">Quản lý Thiết bị</h1>
  <button class="btn btn-primary" onclick="showAddModal()">+ Thêm thiết bị</button>
</div>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-value">@totalDevices</div>
    <div class="stat-label">Tổng thiết bị</div>
  </div>
  <div class="stat-card">
    <div class="stat-value stat-success">@onlineCount</div>
    <div class="stat-label">Online</div>
  </div>
  <div class="stat-card">
    <div class="stat-value stat-danger">@offlineCount</div>
    <div class="stat-label">Offline</div>
  </div>
</div>

@if (!Model.Any())
{
  <div class="empty-state">
    <div style="font-size: 3rem; margin-bottom: 0.75rem;">📱</div>
    <p>Chưa có thiết bị nào</p>
    <button class="btn btn-primary" style="margin-top: 1rem;" onclick="showAddModal()">+ Thêm thiết bị</button>
  </div>
}
else
{
  <div class="grid grid-cols-3">
    @foreach (var device in Model)
    {
      var isOnline = device.LastSeen.HasValue && (utcNow - device.LastSeen.Value).TotalMinutes < 5;
      var currentSchedule = currentByDevice.ContainsKey(device.Id) ? currentByDevice[device.Id] : null;
      var upcomingSchedule = upcomingByDevice.ContainsKey(device.Id) ? upcomingByDevice[device.Id] : null;
      <div class="card">
        <div class="flex items-center justify-between" style="margin-bottom: 0.75rem;">
          <div class="flex items-center gap-2" style="font-weight: 600;">
            <span>📱</span>
            <span>@device.DeviceCode</span>
          </div>
          <span class="badge @(isOnline ? "badge-success" : "badge-danger")">
            <span class="status-dot @(isOnline ? "status-online" : "status-offline")"></span>
            @(isOnline ? "Online" : "Offline")
          </span>
        </div>
        <div class="flex items-center gap-2 text-muted text-sm">📍 @device.Location</div>
        <div class="text-muted text-sm" style="margin-top: 0.5rem;">Đang phát: <strong>@(currentSchedule?.Name ?? "Chưa có")</strong></div>
        <div class="text-muted text-sm">Sắp phát: <strong>@(upcomingSchedule?.Name ?? "Chưa có")</strong></div>
        <div class="flex gap-2" style="padding-top: 0.75rem; margin-top: 0.75rem; border-top: 1px solid var(--border);">
          <button type="button" class="btn btn-ghost btn-sm flex-1" onclick="openDeviceDetail(@device.Id)">Chi tiết</button>
          <form method="post" action="/portal/devices/delete" style="flex: 1;">
            <input type="hidden" name="deviceId" value="@device.Id" />
            <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--destructive); width: 100%;" onclick="return confirm('Bạn có chắc muốn xóa thiết bị này?')">Xóa</button>
          </form>
        </div>
      </div>
    }
  </div>
}

@foreach (var device in Model)
{
  var currentSchedule = currentByDevice.ContainsKey(device.Id) ? currentByDevice[device.Id] : null;
  var upcomingSchedule = upcomingByDevice.ContainsKey(device.Id) ? upcomingByDevice[device.Id] : null;
  var isOnline = device.LastSeen.HasValue && (utcNow - device.LastSeen.Value).TotalMinutes < 5;
  var lastSeenVietnam = device.LastSeen.HasValue ? vietnamNow.Add(device.LastSeen.Value - utcNow).ToString("yyyy-MM-dd HH:mm") : "Chưa có";
  <div class="modal-overlay" id="deviceDetail-@device.Id" style="display: none;">
    <div class="modal modal-wide">
      <div class="modal-header">
        <div>
          <h3 class="modal-title">@device.DeviceCode</h3>
          <p class="text-sm text-muted">Chi tiết thiết bị và lịch phát</p>
        </div>
        <button class="modal-close" type="button" onclick="closeDeviceDetail(@device.Id)">&times;</button>
      </div>
      <div class="grid grid-cols-2" style="gap: 1rem;">
        <div class="card">
          <div class="card-title">Thiết bị</div>
          <div class="text-sm" style="margin-top: .5rem;">Mã: @device.DeviceCode</div>
          <div class="text-sm">Vị trí: @(device.Location ?? "Chưa có")</div>
          <div class="text-sm">Trạng thái: @(isOnline ? "Online" : "Offline")</div>
          <div class="text-sm">Last seen: @lastSeenVietnam</div>
        </div>
        <div class="card">
          <div class="card-title">Đang phát</div>
          @if (currentSchedule == null)
          {
            <div class="text-sm text-muted" style="margin-top: .5rem;">Chưa có schedule đang phát.</div>
          }
          else
          {
            <div class="text-sm" style="margin-top: .5rem;">@currentSchedule.Name</div>
            <div class="text-sm text-muted">@VietnamDate(currentSchedule.StartDate) - @VietnamDate(currentSchedule.EndDate) | @currentSchedule.StartTime - @currentSchedule.EndTime</div>
            <div class="flex flex-wrap gap-2" style="margin-top: .75rem;">
              @foreach (var item in currentSchedule.Items.OrderBy(i => i.OrderIndex))
              {
                <span class="badge badge-secondary">#@(item.OrderIndex + 1) @item.Media.FileName</span>
              }
            </div>
          }
        </div>
      </div>
      <div class="card" style="margin-top: 1rem;">
        <div class="card-title">Sắp phát</div>
        @if (upcomingSchedule == null)
        {
          <div class="text-sm text-muted" style="margin-top: .5rem;">Chưa có schedule sắp tới.</div>
        }
        else
        {
          <div class="text-sm" style="margin-top: .5rem;">@upcomingSchedule.Name</div>
          <div class="text-sm text-muted">@VietnamDate(upcomingSchedule.StartDate) - @VietnamDate(upcomingSchedule.EndDate) | @upcomingSchedule.StartTime - @upcomingSchedule.EndTime</div>
          <div class="flex flex-wrap gap-2" style="margin-top: .75rem;">
            @foreach (var item in upcomingSchedule.Items.OrderBy(i => i.OrderIndex))
            {
              <span class="badge badge-secondary">#@(item.OrderIndex + 1) @item.Media.FileName</span>
            }
          </div>
        }
      </div>
    </div>
  </div>
}

<div class="modal-overlay" id="addModal" style="display: none;">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title">Thêm thiết bị mới</h3>
      <button class="modal-close" onclick="hideAddModal()">&times;</button>
    </div>
    <form method="post" action="/portal/devices">
      <div class="form-group">
        <label class="form-label">Mã thiết bị</label>
        <input type="text" name="deviceCode" class="form-input" placeholder="VM004" required />
      </div>
      <div class="form-group">
        <label class="form-label">Vị trí</label>
        <input type="text" name="location" class="form-input" placeholder="Tầng 1, Tòa nhà D" required />
      </div>
      <div class="flex gap-2" style="margin-top: 1.25rem;">
        <button type="button" class="btn btn-secondary flex-1" onclick="hideAddModal()">Hủy</button>
        <button type="submit" class="btn btn-primary flex-1">Thêm</button>
      </div>
    </form>
  </div>
</div>

<script>
  function showAddModal() { document.getElementById('addModal').style.display = 'flex'; }
  function hideAddModal() { document.getElementById('addModal').style.display = 'none'; }
  function openDeviceDetail(id) { document.getElementById('deviceDetail-' + id).style.display = 'flex'; }
  function closeDeviceDetail(id) { document.getElementById('deviceDetail-' + id).style.display = 'none'; }
</script>
