<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] — VendAD</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:         #0a0a0f;
      --surface:    #111118;
      --border:     #1e1e2e;
      --accent:     #e8ff3c;
      --accent-dim: rgba(232,255,60,0.12);
      --text:       #e2e2f0;
      --muted:      #6b6b80;
      --green:      #39ff7a;
      --red:        #ff4757;
      --mono:       'DM Mono', monospace;
      --display:    'Syne', sans-serif;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--mono);
      font-size: 14px;
      min-height: 100vh;
    }

    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 32px;
      height: 60px;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .logo {
      font-family: var(--display);
      font-size: 20px;
      font-weight: 800;
      letter-spacing: -0.5px;
      color: var(--accent);
    }
    .logo span { color: var(--text); }

    nav a {
      color: var(--muted);
      text-decoration: none;
      font-size: 13px;
      letter-spacing: 0.05em;
      padding: 6px 14px;
      border-radius: 4px;
      transition: color 0.15s, background 0.15s;
    }
    nav a:hover, nav a.active {
      color: var(--accent);
      background: var(--accent-dim);
    }

    main { padding: 40px 32px; max-width: 1200px; margin: 0 auto; }

    h1 {
      font-family: var(--display);
      font-size: 28px;
      font-weight: 800;
      letter-spacing: -1px;
      margin-bottom: 6px;
    }
    .subtitle { color: var(--muted); margin-bottom: 32px; font-size: 13px; }
  </style>
</head>
<body>
  <nav>
    <div class="logo">Vend<span>AD</span></div>
    <div style="display:flex;gap:4px;">
      <a href="/" class="@(Context.Request.Path == "/" || Context.Request.Path == "/dashboard" ? "active" : "")">Dashboard</a>
      <a href="/upload" class="@(Context.Request.Path == "/upload" ? "active" : "")">Upload</a>
    </div>
  </nav>
  <main>
    @RenderBody()
  </main>
</body>
</html>
