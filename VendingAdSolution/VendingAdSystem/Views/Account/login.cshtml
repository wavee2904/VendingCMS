@model LoginRequest
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_LayoutLogin";
}

<div class="login-container">
  <div class="login-shell">
    <section class="login-brand-panel" aria-label="Thông tin hệ thống">
      <div class="login-brand-mark">VA</div>
      <div>
        <h1 class="login-brand-title">VendingAds CMS</h1>
        <p class="login-brand-text">Quản lý video, playlist, lịch phát và thiết bị quảng cáo từ một portal duy nhất.</p>
      </div>
      <div class="login-capability-list">
        <div class="login-capability-item">Lên lịch phát theo giờ Việt Nam</div>
        <div class="login-capability-item">Theo dõi thiết bị và nội dung đang chạy</div>
        <div class="login-capability-item">Đồng bộ video tới device tự động</div>
      </div>
    </section>

    <section class="login-card" aria-label="Đăng nhập">
      <div class="login-header">
        <div class="login-eyebrow">CMS Portal</div>
        <h2 class="login-title">Đăng nhập</h2>
        <p class="login-subtitle">Truy cập hệ thống quản lý quảng cáo.</p>
      </div>

      <form class="login-form" method="post" action="/account/login">
        @if (!ViewData.ModelState.IsValid)
        {
          <div class="alert alert-danger">
            @foreach (var modelState in ViewData.ModelState.Values)
            {
              @foreach (var error in modelState.Errors)
              {
                @error.ErrorMessage<br />
              }
            }
          </div>
        }

        <div class="form-group">
          <label class="form-label" for="loginUsername">Email hoặc username</label>
          <input id="loginUsername" type="text" name="username" class="form-input login-input" placeholder="test@test" autocomplete="username" required />
        </div>

        <div class="form-group">
          <label class="form-label" for="loginPassword">Mật khẩu</label>
          <input id="loginPassword" type="password" name="password" class="form-input login-input" placeholder="••••••••" autocomplete="current-password" required />
        </div>

        <button type="submit" class="btn btn-primary btn-block login-submit">Đăng nhập</button>
      </form>

      <div class="login-demo-box">
        <div class="login-demo-title">Tài khoản demo</div>
        <div class="login-demo-row"><span>Người dùng</span><code>test@test / test@test</code></div>
      </div>
    </section>
  </div>
</div>
