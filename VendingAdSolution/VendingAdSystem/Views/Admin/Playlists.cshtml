@model List<Playlist>
@{
    var devices = (List<Device>)ViewBag.Devices;
    var users = (List<User>)ViewBag.Users;
    int? selectedUserId = ViewBag.SelectedUserId;
    string? keyword = ViewBag.Keyword;
    ViewData["Title"] = "Quản lý toàn bộ danh sách phát";
}

<div class="page-header">
  <h1 class="page-title">Quản lý toàn bộ danh sách phát</h1>
</div>

<form method="get" action="/admin/playlists" class="card" style="margin-bottom: 1rem; display: flex; gap: 0.75rem; align-items: end; flex-wrap: wrap;">
  <div class="form-group u-fg-inline-220">
    <label class="form-label">Người dùng</label>
    <select name="userId" class="form-input">
      <option value="">Tất cả người dùng</option>
      @foreach (var user in users)
      {
        <option value="@user.Id" selected="@(selectedUserId == user.Id)">@user.Username</option>
      }
    </select>
  </div>
  <div class="form-group u-fg-inline-260">
    <label class="form-label">Tìm kiếm</label>
    <input type="text" name="keyword" value="@keyword" class="form-input" placeholder="Tên danh sách phát hoặc video" />
  </div>
  <button type="submit" class="btn btn-primary fx-btn">Lọc</button>
  <a href="/admin/playlists" class="btn btn-secondary fx-soft">Xóa bộ lọc</a>
</form>

<div class="table-wrapper">
  @if (!Model.Any())
  {
    <div class="empty-state">
      <div class="u-empty-icon-lg">📋</div>
      <p>Chưa có playlist nào.</p>
    </div>
  }
  else
  {
    <table class="table">
      <thead>
        <tr class="fx-list-row">
          <th>Danh sách phát</th>
          <th>Người dùng</th>
          <th>Thiết bị</th>
          <th>Video</th>
          <th>Thời gian</th>
          <th>Trạng thái</th>
          <th>Hành động</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var playlist in Model)
        {
          <tr class="fx-list-row">
            <td><strong style="color: var(--primary);">@playlist.Name</strong></td>
            <td><span class="badge badge-primary">@(playlist.User?.Username ?? "-")</span></td>
            <td>@playlist.Items.Count video</td>
            <td class="text-muted text-sm">Chỉ là mẫu</td>
            <td><span class="badge @(playlist.IsActive ? "badge-success" : "badge-danger")">@(playlist.IsActive ? "Đang hoạt động" : "Đã tắt")</span></td>
            <td>
              <div class="action-buttons">
                <button class="btn btn-sm btn-secondary" onclick="toggleEdit(@playlist.Id)">Sửa</button>
                <form method="post" action="/admin/playlists/delete" onsubmit="return confirm('Xóa playlist @playlist.Name?')">
                  <input type="hidden" name="playlistId" value="@playlist.Id" />
                  <button type="submit" class="btn btn-sm btn btn-sm u-btn-danger-soft">Xóa</button>
                </form>
              </div>
            </td>
          </tr>
          <tr id="edit-@playlist.Id" style="display: none;">
            <td colspan="7">
              <form method="post" action="/admin/playlists/update">
                <input type="hidden" name="playlistId" value="@playlist.Id" />
                <div class="u-grid-2-gap">
                  <div class="form-group">
                    <label class="form-label">Tên playlist</label>
                    <input type="text" name="name" class="form-input" value="@playlist.Name" required />
                  </div>
                  <div class="form-group">
                    <label class="form-label">Trạng thái</label>
                    <label class="form-label u-flex-inline-center-gap">
                      <input type="checkbox" name="isActive" value="true" @(playlist.IsActive ? "checked" : "") /> Đang hoạt động
                    </label>
                  </div>
                  </div>
                <button type="submit" class="btn btn-primary fx-btn">Lưu playlist</button>
              </form>
            </td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>

<script>
  function toggleEdit(id) {
    const row = document.getElementById('edit-' + id);
    row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
  }
</script>
