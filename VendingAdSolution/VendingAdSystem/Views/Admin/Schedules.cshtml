@model List<PlaybackSchedule>
@{
    var users = (List<User>)ViewBag.Users;
    var devices = (List<Device>)ViewBag.Devices;
    int? selectedUserId = ViewBag.SelectedUserId;
    int? selectedDeviceId = ViewBag.SelectedDeviceId;
    string? keyword = ViewBag.Keyword;
    ViewData["Title"] = "Quản lý lịch phát";
    var vietnamTimeZone = TimeZoneInfo.FindSystemTimeZoneById("SE Asia Standard Time");
    string VietnamDate(DateTime utcDate) => TimeZoneInfo.ConvertTimeFromUtc(utcDate, vietnamTimeZone).ToString("dd/MM/yyyy");
    string DateRangeText(PlaybackSchedule schedule) => VietnamDate(schedule.StartDate) == VietnamDate(schedule.EndDate) ? VietnamDate(schedule.StartDate) : $"{VietnamDate(schedule.StartDate)} - {VietnamDate(schedule.EndDate)}";
    string TimeRangeText(PlaybackSchedule schedule) => $"{schedule.StartTime:hh\\:mm} - {schedule.EndTime:hh\\:mm}";
}

<div class="page-header">
  <h1 class="page-title">Quản lý lịch phát</h1>
</div>

<form method="get" action="/admin/schedules" class="card" style="margin-bottom: 1rem; display: flex; gap: 0.75rem; align-items: end; flex-wrap: wrap;">
  <div class="form-group u-fg-inline-220">
    <label class="form-label">Người dùng</label>
    <select name="userId" class="form-input">
      <option value="">Tất cả người dùng</option>
      @foreach (var user in users)
      {
        <option value="@user.Id" selected="@(selectedUserId == user.Id)">@user.Username</option>
      }
    </select>
  </div>
  <div class="form-group u-fg-inline-220">
    <label class="form-label">Thiết bị</label>
    <select name="deviceId" class="form-input">
      <option value="">Tất cả thiết bị</option>
      @foreach (var device in devices)
      {
        <option value="@device.Id" selected="@(selectedDeviceId == device.Id)">@device.DeviceCode</option>
      }
    </select>
  </div>
  <div class="form-group u-fg-inline-260">
    <label class="form-label">Tìm kiếm</label>
    <input type="text" name="keyword" value="@keyword" class="form-input" placeholder="Tên lịch phát, người dùng, video" />
  </div>
  <button type="submit" class="btn btn-primary fx-btn">Lọc</button>
  <a href="/admin/schedules" class="btn btn-secondary fx-soft">Xóa bộ lọc</a>
</form>

<div class="table-wrapper">
  @if (!Model.Any())
  {
    <div class="empty-state">
      <div class="u-empty-icon-lg">🗓️</div>
      <p>Chưa có lịch phát nào.</p>
    </div>
  }
  else
  {
    <table class="table">
      <thead>
        <tr class="fx-list-row">
          <th>Tên</th>
          <th>Người dùng</th>
          <th>Thiết bị</th>
          <th>Nội dung</th>
          <th>Khung giờ</th>
          <th>Trạng thái</th>
          <th>Hành động</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var s in Model)
        {
          <tr class="fx-list-row">
            <td><strong style="color: var(--primary);">@s.Name</strong></td>
            <td><span class="badge badge-primary">@(s.User?.Username ?? "-")</span></td>
            <td>
              @foreach (var d in s.Devices.OrderBy(x => x.Device.DeviceCode))
              {
                <span class="badge badge-secondary u-mr-035">@d.Device.DeviceCode</span>
              }
            </td>
            <td>@s.Items.Count video</td>
            <td><div class="schedule-time-row"><span class="time-chip time-chip-date">@DateRangeText(s)</span><span class="time-chip time-chip-clock">@TimeRangeText(s)</span></div></td>
            <td><span class="badge @(s.IsActive ? "badge-success" : "badge-danger")">@(s.IsActive ? "Đang hoạt động" : "Đã tắt")</span></td>
            <td>
              <div class="action-buttons">
                <form method="post" action="/admin/schedules/toggle">
                  <input type="hidden" name="scheduleId" value="@s.Id" />
                  <button type="submit" class="btn btn-sm btn-secondary">@(s.IsActive ? "Tắt" : "Bật")</button>
                </form>
                <form method="post" action="/admin/schedules/delete" onsubmit="return confirm('Xóa schedule @s.Name?')">
                  <input type="hidden" name="scheduleId" value="@s.Id" />
                  <button type="submit" class="btn btn-sm btn btn-sm u-btn-danger-soft">Xóa</button>
                </form>
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>
