@model List<Media>
@{
    var users = (List<User>)ViewBag.Users;
    int? selectedUserId = ViewBag.SelectedUserId;
    string? keyword = ViewBag.Keyword;
    ViewData["Title"] = "Quản lý toàn bộ Video";
}

<div class="page-header">
  <h1 class="page-title">Quản lý toàn bộ Video</h1>
</div>

<form method="get" action="/admin/videos" class="card" style="margin-bottom: 1rem; display: flex; gap: 0.75rem; align-items: end; flex-wrap: wrap;">
  <div class="form-group u-fg-inline-220">
    <label class="form-label">Người dùng</label>
    <select name="userId" class="form-input">
      <option value="">Tất cả người dùng</option>
      @foreach (var user in users)
      {
        <option value="@user.Id" selected="@(selectedUserId == user.Id)">@user.Username</option>
      }
    </select>
  </div>
  <div class="form-group u-fg-inline-260">
    <label class="form-label">Tìm kiếm</label>
    <input type="text" name="keyword" value="@keyword" class="form-input" placeholder="Tên video hoặc danh sách phát" />
  </div>
  <button type="submit" class="btn btn-primary fx-btn">Lọc</button>
  <a href="/admin/videos" class="btn btn-secondary fx-soft">Xóa bộ lọc</a>
</form>

<div class="table-wrapper">
  @if (!Model.Any())
  {
    <div class="empty-state">
      <div class="u-empty-icon-lg">🎬</div>
      <p>Chưa có video nào.</p>
    </div>
  }
  else
  {
    <table class="table">
      <thead>
        <tr class="fx-list-row">
          <th>Video</th>
      <th>Người dùng</th>
      <th>Danh sách phát</th>
          <th>Thiết bị</th>
          <th>Dung lượng</th>
          <th>Ngày upload</th>
      <th>Hành động</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var video in Model)
        {
          <tr class="fx-list-row">
            <td>@video.FileName</td>
            <td><span class="badge badge-primary">@(video.User?.Username ?? "-")</span></td>
            <td>
              @foreach (var playlist in video.PlaylistItems.Select(i => i.Playlist).DistinctBy(p => p.Id).OrderBy(p => p.Name))
              {
                <span class="badge badge-secondary u-mr-035">@playlist.Name</span>
              }
            </td>
            <td><span class="text-muted">Lịch phát</span></td>
            <td>@(video.FileSize / 1024 / 1024) MB</td>
            <td class="text-muted text-sm">@TimeZoneInfo.ConvertTimeFromUtc(video.UploadedAt, TimeZoneInfo.FindSystemTimeZoneById("SE Asia Standard Time")).ToString("yyyy-MM-dd HH:mm")</td>
            <td>
              <div class="action-buttons">
                <a class="btn btn-sm btn-secondary" href="@video.FileUrl" target="_blank">Xem</a>
                <form method="post" action="/admin/videos/delete" onsubmit="return confirm('Xóa video @video.FileName?')">
                  <input type="hidden" name="videoId" value="@video.Id" />
                  <button type="submit" class="btn btn-sm btn btn-sm u-btn-danger-soft">Xóa</button>
                </form>
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>
