@{
    ViewData["Title"] = "Upload Media";
}

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 36px 40px;
    max-width: 500px;
  }

  .field { margin-bottom: 22px; }

  label {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 8px;
  }

  input[type="text"] {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    font-family: var(--mono);
    font-size: 14px;
    padding: 11px 14px;
    outline: none;
    transition: border-color 0.15s;
  }
  input[type="text"]:focus { border-color: var(--accent); }

  .file-drop {
    width: 100%;
    background: var(--bg);
    border: 1px dashed var(--border);
    border-radius: 6px;
    padding: 28px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    position: relative;
  }
  .file-drop:hover, .file-drop.drag { border-color: var(--accent); background: var(--accent-dim); }
  .file-drop input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
  .file-drop-icon { font-size: 28px; margin-bottom: 8px; }
  .file-drop-label { color: var(--muted); font-size: 13px; }
  .file-drop-name  { color: var(--accent); font-size: 13px; margin-top: 6px; }

  .progress-bar { background: var(--border); border-radius: 4px; height: 4px; margin-top: 20px; overflow: hidden; display: none; }
  .progress-fill { height: 100%; background: var(--accent); width: 0; transition: width 0.2s; border-radius: 4px; }

  button {
    width: 100%;
    background: var(--accent);
    color: #0a0a0f;
    border: none;
    border-radius: 6px;
    font-family: var(--display);
    font-size: 15px;
    font-weight: 700;
    padding: 13px 28px;
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: opacity 0.15s;
    margin-top: 4px;
  }
  button:hover:not(:disabled) { opacity: 0.85; }
  button:disabled { opacity: 0.35; cursor: not-allowed; }

  .alert {
    margin-top: 20px;
    padding: 14px 16px;
    border-radius: 6px;
    font-size: 13px;
    display: none;
    line-height: 1.5;
  }
  .alert-ok  { background: rgba(57,255,122,0.1);  color: var(--green); border: 1px solid rgba(57,255,122,0.25); }
  .alert-err { background: rgba(255,71,87,0.1);   color: var(--red);   border: 1px solid rgba(255,71,87,0.25); }
</style>

<h1>Upload Media</h1>
<p class="subtitle">Assign a video file to a tablet device</p>

<div class="card">
  <div class="field">
    <label>Device Code</label>
    <input type="text" id="deviceCode" placeholder="e.g. TABLET-001" />
  </div>

  <div class="field">
    <label>Video File</label>
    <div class="file-drop" id="dropZone">
      <input type="file" id="videoFile" accept="video/*" onchange="onFileChange(this)" />
      <div class="file-drop-icon">🎬</div>
      <div class="file-drop-label">Click to browse or drag & drop</div>
      <div class="file-drop-name" id="fileName"></div>
    </div>
  </div>

  <div class="progress-bar" id="progressBar">
    <div class="progress-fill" id="progressFill"></div>
  </div>

  <button id="uploadBtn" onclick="doUpload()">Upload &amp; Assign →</button>
  <div class="alert" id="alert"></div>
</div>

<script>
function onFileChange(input) {
  const name = input.files[0]?.name;
  document.getElementById('fileName').textContent = name ?? '';
}

async function doUpload() {
  const code  = document.getElementById('deviceCode').value.trim();
  const file  = document.getElementById('videoFile').files[0];
  const btn   = document.getElementById('uploadBtn');
  const alert = document.getElementById('alert');
  const bar   = document.getElementById('progressBar');
  const fill  = document.getElementById('progressFill');

  if (!code)  { showAlert('err', 'Please enter a Device Code.'); return; }
  if (!file)  { showAlert('err', 'Please select a video file.'); return; }

  btn.disabled = true;
  btn.textContent = 'Uploading…';
  alert.style.display = 'none';
  bar.style.display = 'block';
  fill.style.width = '0%';

  const fd = new FormData();
  fd.append('file', file);
  fd.append('deviceCode', code);

  return new Promise((resolve) => {
    const xhr = new XMLHttpRequest();
    xhr.open('POST', '/api/media/upload');

    xhr.upload.onprogress = (e) => {
      if (e.lengthComputable) {
        fill.style.width = Math.round(e.loaded / e.total * 100) + '%';
      }
    };

    xhr.onload = () => {
      btn.disabled = false;
      btn.textContent = 'Upload & Assign →';
      bar.style.display = 'none';
      try {
        const data = JSON.parse(xhr.responseText);
        if (xhr.status === 200) {
          showAlert('ok', `✓ "${data.fileName}" assigned to ${data.deviceCode}`);
          document.getElementById('videoFile').value = '';
          document.getElementById('fileName').textContent = '';
        } else {
          showAlert('err', '✗ ' + (data.message ?? 'Upload failed'));
        }
      } catch {
        showAlert('err', '✗ Unexpected server response');
      }
      resolve();
    };

    xhr.onerror = () => {
      btn.disabled = false;
      btn.textContent = 'Upload & Assign →';
      bar.style.display = 'none';
      showAlert('err', '✗ Network error — is the server running?');
      resolve();
    };

    xhr.send(fd);
  });
}

function showAlert(type, msg) {
  const el = document.getElementById('alert');
  el.className = 'alert alert-' + type;
  el.textContent = msg;
  el.style.display = 'block';
}
</script>
