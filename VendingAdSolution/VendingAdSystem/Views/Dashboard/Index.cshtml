@model List<Device>
@{
    ViewData["Title"] = "Dashboard";
}

<style>
  .stats { display: flex; gap: 16px; margin-bottom: 32px; flex-wrap: wrap; }
  .stat {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px 28px;
    min-width: 140px;
  }
  .stat-val {
    font-family: var(--display);
    font-size: 36px;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 4px;
  }
  .stat-label { color: var(--muted); font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; }
  .online-val  { color: var(--green); }
  .offline-val { color: var(--red); }

  .table-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  table { width: 100%; border-collapse: collapse; }
  thead tr { border-bottom: 2px solid var(--border); }
  th {
    text-align: left;
    padding: 10px 16px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }
  tbody tr { border-bottom: 1px solid var(--border); transition: background 0.1s; }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: rgba(255,255,255,0.02); }
  td { padding: 14px 16px; vertical-align: middle; }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
  }
  .badge-online  { background: rgba(57,255,122,0.12); color: var(--green); }
  .badge-offline { background: rgba(255,71,87,0.12);  color: var(--red); }

  .dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
  .pulse { animation: blink 1.8s ease-in-out infinite; }
  @@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.25} }

  .device-code { color: var(--accent); letter-spacing: 0.04em; }
  .media-name  { color: var(--muted); font-size: 13px; }
  .timestamp   { color: var(--muted); font-size: 12px; }

  .empty { text-align: center; padding: 64px 32px; color: var(--muted); }
  .empty-icon { font-size: 40px; margin-bottom: 12px; }

  .footer-hint { color: var(--muted); font-size: 12px; margin-top: 14px; text-align: right; }
</style>

<h1>Device Dashboard</h1>
<p class="subtitle">Real-time status of all registered tablets</p>

@{
    var online  = Model.Count(d => d.LastSeen.HasValue && (DateTime.UtcNow - d.LastSeen.Value).TotalMinutes < 5);
    var offline = Model.Count - online;
}

<div class="stats">
  <div class="stat">
    <div class="stat-val">@Model.Count</div>
    <div class="stat-label">Total Devices</div>
  </div>
  <div class="stat">
    <div class="stat-val online-val">@online</div>
    <div class="stat-label">Online</div>
  </div>
  <div class="stat">
    <div class="stat-val offline-val">@offline</div>
    <div class="stat-label">Offline</div>
  </div>
</div>

<div class="table-wrap">
  @if (!Model.Any())
  {
    <div class="empty">
      <div class="empty-icon">📟</div>
      <div>No devices registered yet.</div>
      <div style="margin-top:6px;font-size:12px;">Tablets appear automatically after their first heartbeat.</div>
    </div>
  }
  else
  {
    <table>
      <thead>
        <tr>
          <th>Status</th>
          <th>Device Code</th>
          <th>Assigned Media</th>
          <th>Last Seen (UTC)</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var device in Model)
        {
          var isOnline = device.LastSeen.HasValue &&
                         (DateTime.UtcNow - device.LastSeen.Value).TotalMinutes < 5;
          var campaign = device.Campaigns.FirstOrDefault();

          <tr>
            <td>
              @if (isOnline)
              {
                <span class="badge badge-online">
                  <span class="dot pulse"></span>Online
                </span>
              }
              else
              {
                <span class="badge badge-offline">
                  <span class="dot"></span>Offline
                </span>
              }
            </td>
            <td><span class="device-code">@device.DeviceCode</span></td>
            <td>
              @if (campaign?.Media != null)
              {
                <span class="media-name">@campaign.Media.FileName</span>
              }
              else
              {
                <span class="media-name">— no media assigned —</span>
              }
            </td>
            <td class="timestamp">
              @(device.LastSeen.HasValue
                ? device.LastSeen.Value.ToString("yyyy-MM-dd HH:mm:ss")
                : "Never")
            </td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>

<p class="footer-hint">
  🟢 Online = heartbeat received within last 5 minutes &nbsp;·&nbsp; Auto-refreshes every 30s
</p>

<script>
  // Auto-refresh page every 30 seconds
  setTimeout(() => location.reload(), 30_000);
</script>
