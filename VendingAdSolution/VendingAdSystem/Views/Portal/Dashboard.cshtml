@using VendingAdSystem.Application.DTOs
@model DashboardViewModel
@{
    ViewData["Title"] = "Bảng điều khiển";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

<div class="dashboard-page">
    <header class="dashboard-topbar">
        <div>
            <nav class="dashboard-breadcrumb" aria-label="breadcrumb">
                <span>@Model.BreadcrumbSection</span>
                <i class="bi bi-chevron-right"></i>
                <span class="active">@Model.BreadcrumbPage</span>
            </nav>
            <h1 class="dashboard-title">@Model.Title</h1>
            <p class="dashboard-subtitle">@Model.Subtitle</p>
        </div>

        <div class="dashboard-actions">
            <button class="btn-soft"><i class="bi bi-calendar3"></i>@Model.DateFilterLabel</button>
            <button class="btn-soft" onclick="location.reload()"><i class="bi bi-arrow-clockwise"></i>Làm mới</button>
            <button class="icon-btn" aria-label="Thông báo"><i class="bi bi-bell"></i><span class="dot">3</span></button>
            <button class="profile-btn">
                <span class="avatar">C</span>
                <span class="profile-meta"><strong>Coca-Cola Manager</strong><small>Quản trị viên</small></span>
                <i class="bi bi-chevron-down"></i>
            </button>
        </div>
    </header>

    @await Html.PartialAsync("~/Views/Shared/Components/_KpiCards.cshtml", Model.Kpis)

    <section class="schedule-grid">
        @await Html.PartialAsync("~/Views/Shared/Components/_NowPlaying.cshtml", Model.NowPlaying)
        @await Html.PartialAsync("~/Views/Shared/Components/_Upcoming.cshtml", Model.Upcoming)
    </section>

    @await Html.PartialAsync("~/Views/Shared/Components/_DeviceGrid.cshtml", Model.Devices)
</div>

<script>
  window.quickPlayDeviceMap = window.quickPlayDeviceMap || {};
</script>
