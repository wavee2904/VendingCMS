@model List<Playlist>
@{
    var medias = (List<Media>)ViewBag.Medias;
    ViewData["Title"] = "Danh sách phát";
    var totalVideos = Model.Sum(p => p.Items.Count);
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

<div class="playlist-page">
  <header class="playlist-topbar">
    <div>
      <nav class="dashboard-breadcrumb" aria-label="breadcrumb">
        <span>Danh mục</span><i class="bi bi-chevron-right"></i><span class="active">Danh sách phát</span>
      </nav>
      <h1 class="dashboard-title">Danh sách phát</h1>
      <p class="dashboard-subtitle">Tạo template nội dung từ video đã upload, sau đó dùng lại khi lên lịch phát.</p>
    </div>

    <div class="video-stat-actions">
      <article class="video-stat-card fx-card"><i class="bi bi-collection-play"></i><div><strong>@Model.Count</strong><span>Tổng playlist</span></div></article>
      <article class="video-stat-card fx-card"><i class="bi bi-collection"></i><div><strong>@totalVideos</strong><span>Tổng video</span></div></article>
    </div>
  </header>

  <section class="playlist-create-card">
    <div class="playlist-create-head">
      <span class="playlist-create-icon"><i class="bi bi-play-fill"></i></span>
      <div>
        <h3>Tạo playlist mới</h3>
        <p>Playlist là mẫu nội dung, chưa gắn thiết bị hoặc khung giờ phát.</p>
      </div>
    </div>
    <form method="post" action="/portal/playlist/create" class="playlist-create-form">
      <input id="playlistNameInput" type="text" name="name" value="@ViewBag.PlaylistDraftName" placeholder="Nhập tên playlist mới..." required />
      <button type="submit">Tạo playlist</button>
    </form>
  </section>

  @if (Model == null || !Model.Any())
  {
    <section class="playlist-empty-state">
      <div class="playlist-empty-icon"><i class="bi bi-collection-play"></i></div>
      <h2>Chưa có playlist nào</h2>
      <p>Tạo playlist rồi thêm video từ kho video.</p>
      <a href="/portal/videos" class="video-upload-btn playlist-empty-cta">Đến kho video</a>
      <div class="playlist-tip-box">
        <strong>Gợi ý</strong>
        <span>Bạn có thể tạo nhiều playlist cho các mục đích khác nhau như: quảng cáo, khuyến mãi, sự kiện, giờ vàng...</span>
      </div>
    </section>
  }
  else
  {
    <section class="playlist-list-card">
      @foreach (var playlist in Model)
      {
        var items = playlist.Items.OrderBy(i => i.OrderIndex).ToList();
        <article class="playlist-item-card">
          <header>
            <div>
              <h3>@playlist.Name</h3>
              <p>Template nội dung có thể dùng lại khi tạo lịch phát.</p>
            </div>
            <div class="playlist-item-tools">
              <span class="pill-counter">@items.Count video</span>
              <button type="button" class="btn-soft fx-soft" onclick="openVideoModal(@playlist.Id)"><i class="bi bi-plus-circle"></i>Thêm video</button>
              <form method="post" action="/portal/playlist/delete" onsubmit="return confirm('Xóa playlist @playlist.Name?')">
                <input type="hidden" name="playlistId" value="@playlist.Id" />
                <button type="submit" class="btn-soft danger"><i class="bi bi-trash"></i>Xóa</button>
              </form>
            </div>
          </header>

          @if (!items.Any())
          {
            <div class="empty-box playlist-empty-min">Danh sách phát chưa có video.</div>
          }
          else
          {
            <div class="playlist-media-list" data-playlist-id="@playlist.Id">
              @foreach (var item in items)
              {
                <div class="playlist-media-row" draggable="true" data-playlist-item-id="@item.Id">
                  <span class="drag">⋮⋮</span>
                  <span class="index">@(item.OrderIndex + 1)</span>
                  <span class="name">@item.Media.FileName</span>
                  <span class="size">@((item.Media.FileSize / 1024 / 1024).ToString()) MB</span>
                  <form method="post" action="/portal/playlist/remove-item" onsubmit="return confirm('Xóa video này khỏi playlist?')">
                    <input type="hidden" name="playlistItemId" value="@item.Id" />
                    <button type="submit" class="btn-soft danger">Xóa</button>
                  </form>
                </div>
              }
            </div>
          }
        </article>
      }
      <div class="text-center playlist-save-order"><button class="video-upload-btn playlist-save-btn" onclick="saveOrder()">Lưu tất cả thay đổi thứ tự</button></div>
    </section>
  }
</div>

<div class="modal-overlay u-hidden" id="videoModal">
  <div class="modal modal-wide">
    <div class="modal-header">
      <div><div class="modal-title">Thêm video từ thư viện</div><p class="text-sm text-muted">Chọn một hoặc nhiều video đã upload.</p></div>
      <button class="modal-close" type="button" onclick="closeVideoModal()">×</button>
    </div>
    <form method="post" action="/portal/playlist/add-video">
      <input type="hidden" name="playlistId" id="modalPlaylistId" />
      <div class="modal-body">
        @if (!medias.Any())
        {<div class="empty-state">Chưa có video trong thư viện.</div>}
        else
        {
          <div class="table-wrapper"><table class="table"><thead><tr class="fx-list-row"><th class="u-w-56">Chọn</th><th>Video</th><th>Dung lượng</th></tr></thead><tbody>
          @foreach (var media in medias)
          {<tr class="fx-list-row"><td><input type="checkbox" name="mediaIds" value="@media.Id" /></td><td>@media.FileName</td><td>@(media.FileSize / 1024 / 1024) MB</td></tr>}
          </tbody></table></div>
        }
      </div>
      <div class="flex justify-between" style="margin-top: 1rem; gap: 1rem;"><button type="button" class="btn btn-secondary fx-soft" onclick="closeVideoModal()">Hủy</button><button type="submit" class="btn btn-primary fx-btn">Thêm video</button></div>
    </form>
  </div>
</div>

<script>
  let draggedItem = null;
  function openVideoModal(playlistId){ document.getElementById('modalPlaylistId').value = playlistId; document.getElementById('videoModal').style.display='flex'; }
  function closeVideoModal(){ document.getElementById('videoModal').style.display='none'; }
  document.querySelectorAll('.playlist-media-row').forEach(item=>{
    item.addEventListener('dragstart', function(e){ draggedItem=this; this.classList.add('dragging'); e.dataTransfer.effectAllowed='move';});
    item.addEventListener('dragend', function(){ this.classList.remove('dragging'); draggedItem=null; updateOrderNumbers();});
    item.addEventListener('dragover', function(e){ e.preventDefault();});
    item.addEventListener('drop', function(e){ e.preventDefault(); if(draggedItem&&draggedItem!==this){ const c=this.parentNode; const items=Array.from(c.querySelectorAll('.playlist-media-row')); const from=items.indexOf(draggedItem); const to=items.indexOf(this); if(from<to){c.insertBefore(draggedItem,this.nextSibling);}else{c.insertBefore(draggedItem,this);} updateOrderNumbers(); }});
  });
  function updateOrderNumbers(){ document.querySelectorAll('.playlist-media-list').forEach(list=>{ list.querySelectorAll('.playlist-media-row').forEach((item,i)=>{ item.querySelector('.index').textContent=i+1; }); }); }
  async function saveOrder(){
    const lists=document.querySelectorAll('.playlist-media-list');
    for(const list of lists){
      const updates=[]; list.querySelectorAll('.playlist-media-row').forEach((item,i)=>updates.push({playlistItemId:parseInt(item.dataset.playlistItemId),orderIndex:i}));
      const resp=await fetch('/portal/playlist/update-order',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({playlistId:parseInt(list.dataset.playlistId),updates})});
      if(!resp.ok){ window.showToast('Lưu thứ tự thất bại','error'); return; }
    }
    window.showToast('Thứ tự playlist đã được lưu!','success');
  }
</script>
