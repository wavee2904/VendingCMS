@model List<Media>
@{
    ViewData["Title"] = "Thư viện video";
    const string videoPlaceholder = "/images/video-placeholder.svg";
    var totalSizeMb = Model.Sum(v => v.FileSize) / 1024 / 1024;
    var videoQuery = ViewBag.VideoQuery as string ?? string.Empty;
    var videoSortBy = ViewBag.VideoSortBy as string ?? "uploadedAt";
    var videoSortDir = ViewBag.VideoSortDir as string ?? "desc";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

<div class="video-page">
  <header class="video-topbar">
    <div>
      <nav class="dashboard-breadcrumb" aria-label="breadcrumb">
        <span>Danh mục</span><i class="bi bi-chevron-right"></i><span class="active">Thư viện video</span>
      </nav>
      <h1 class="dashboard-title">Thư viện video</h1>
      <p class="dashboard-subtitle">Upload một lần, sử dụng cho playlist và lịch phát.</p>
    </div>

    <div class="video-stat-actions">
      <article class="video-stat-card fx-card"><i class="bi bi-collection-play"></i><div><strong>@Model.Count</strong><span>Tổng video</span></div></article>
      <article class="video-stat-card fx-card"><i class="bi bi-sd-card"></i><div><strong>@totalSizeMb MB</strong><span>Tổng dung lượng</span></div></article>
    </div>
  </header>

  <section class="video-upload-board">
    <div class="video-drop-area" id="dropZone" onclick="document.getElementById('videoFile').click()" ondragover="onDropDragOver(event)" ondragleave="onDropDragLeave(event)" ondrop="onDropFile(event)">
      <input type="file" id="videoFile" accept="video/*" onchange="onFileSelect(this)" hidden />
      <div class="upload-circle"><i class="bi bi-cloud-arrow-up-fill"></i></div>
      <h3>Kéo & thả video vào đây</h3>
      <p>hoặc click để chọn file</p>
      <small>Hỗ trợ: MP4, AVI, MOV · Tối đa 50MB</small>
      <button type="button" class="video-select-btn">Chọn file từ máy</button>
      <p id="fileName" class="media-selected-file"></p>
      <div id="uploadLoading" class="upload-loading u-hidden" style="display:none" aria-live="polite"><span class="upload-spinner"></span><span>Đang tải video...</span></div>
      
    </div>

    <aside class="video-guide">
      <h3>Quy trình sử dụng</h3>
      <ol>
        <li>Tải video vào thư viện cá nhân.</li>
        <li>Tạo danh sách phát nếu muốn tái sử dụng nhiều video.</li>
        <li>Lên lịch phát và chọn thiết bị ở trang Lịch phát.</li>
      </ol>
      <div class="video-guide-note"><i class="bi bi-info-circle"></i>Thiết bị mobile/TV box sẽ tải video về local trước khi phát.</div>
    </aside>
  </section>

  <section class="video-library-card">
    <header class="video-library-head">
      <div>
        <h2>Danh sách video (@Model.Count)</h2>
        <p>Chọn nhiều để xóa, hoặc mở danh sách phát/lịch phát từ kho này.</p>
      </div>
      <div class="video-tools">
        <form method="get" action="/portal/videos" id="videoFilterForm" class="video-tools" style="gap:.6rem;">
          <div class="search-box"><i class="bi bi-search"></i><input type="text" name="q" value="@videoQuery" placeholder="Tìm kiếm video..." /></div>
          <select class="btn-soft fx-soft" name="sortBy" onchange="document.getElementById('videoFilterForm').submit()">
            <option value="uploadedAt" selected="@(videoSortBy == "uploadedat")">Ngày tải lên</option>
            <option value="fileName" selected="@(videoSortBy == "filename")">Tên video</option>
            <option value="fileSize" selected="@(videoSortBy == "filesize")">Dung lượng</option>
          </select>
          <select class="btn-soft fx-soft" name="sortDir" onchange="document.getElementById('videoFilterForm').submit()">
            <option value="desc" selected="@(videoSortDir == "desc")">Giảm dần</option>
            <option value="asc" selected="@(videoSortDir == "asc")">Tăng dần</option>
          </select>
          <button type="submit" class="u-hidden" aria-hidden="true">submit</button>
        </form>
        <button class="btn-soft danger" type="button" id="toggleDeleteModeBtn" onclick="toggleDeleteMode()"><i class="bi bi-trash"></i>Xóa đã chọn</button>
        <div id="deleteActions" class="u-hidden" style="gap:.5rem;">
          <button type="button" class="btn-soft fx-soft" onclick="cancelDeleteMode()">Hủy</button>
          <button type="button" class="btn-soft danger" onclick="confirmBatchDelete()">Xác nhận xóa</button>
        </div>
      </div>
    </header>

    @if (!Model.Any())
    {
      <div class="empty-box video-empty-min">Chưa có video nào trong thư viện.</div>
    }
    else
    {
      <div class="video-table-wrap">
        <table class="video-table">
          <tbody>
          @foreach (var video in Model)
          {
            var playlists = video.PlaylistItems.Select(i => i.Playlist).DistinctBy(p => p.Id).ToList();
            <tr class="fx-list-row">
              <td class="col-check delete-col u-hidden"><input type="checkbox" class="delete-check" value="@video.Id" /></td>
              <td class="col-media">
                <img src="@(string.IsNullOrWhiteSpace(video.ThumbnailUrl) ? videoPlaceholder : video.ThumbnailUrl)" onerror="this.onerror=null;this.src='@videoPlaceholder';" alt="thumb" />
                <div>
                  <strong>@video.FileName</strong>
                  <small>Video thư viện</small>
                </div>
              </td>
              <td><strong>@(video.FileSize / 1024 / 1024) MB</strong><small>Dung lượng</small></td>
              <td><strong>@TimeZoneInfo.ConvertTimeFromUtc(video.UploadedAt, TimeZoneInfo.FindSystemTimeZoneById("SE Asia Standard Time")).ToString("dd/MM/yyyy")</strong><small>Ngày tải lên</small></td>
              <td><strong>@playlists.Count playlist</strong><small>Đang sử dụng</small></td>
              <td class="col-actions">
                <button class="icon-btn" title="Xem"><i class="bi bi-eye"></i></button>
                <form method="post" action="/portal/videos/delete" class="u-inline">
                  <input type="hidden" name="videoId" value="@video.Id" />
                  <button class="icon-btn danger-outline" type="submit" onclick="return confirm('Bạn có chắc muốn xóa video này?')"><i class="bi bi-trash"></i></button>
                </form>
              </td>
            </tr>
          }
          </tbody>
        </table>
      </div>
      <div class="video-list-foot">Hiển thị 1 đến @Model.Count của @Model.Count video</div>
    }
  </section>
</div>

<script>
  var userId = @Context.Session.GetInt32("UserId");

  var uploadLoadingEl = document.getElementById('uploadLoading');
  if (uploadLoadingEl) {
    uploadLoadingEl.classList.add('u-hidden');
    uploadLoadingEl.style.display = 'none';
  }

  function onFileSelect(input) {
    var file = input.files[0];
    if (!file) return;
    if (file.size > 50 * 1024 * 1024) { window.showToast('File phải nhỏ hơn 50MB', 'error'); input.value = ''; return; }
    document.getElementById('fileName').textContent = file.name;
    doUpload();
  }

  async function doUpload() {
    var file = document.getElementById('videoFile').files[0];
    if (!file) return;
    var formData = new FormData();
    formData.append('file', file); formData.append('userId', userId);
    var xhr = new XMLHttpRequest(); xhr.open('POST', '/api/portal/upload');
    document.getElementById('uploadLoading').classList.remove('u-hidden'); document.getElementById('uploadLoading').style.display='flex';
    document.getElementById('dropZone').classList.add('uploading');
    xhr.upload.onprogress = function(e) { };
    xhr.onload = async function(){
      if(xhr.status===200){
        try {
          const res = await fetch(window.location.href, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
          const html = await res.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const newLibrary = doc.querySelector('.video-library-card');
          const newStats = doc.querySelector('.video-stat-actions');
          if (newLibrary) {
            const currentLibrary = document.querySelector('.video-library-card');
            if (currentLibrary) currentLibrary.replaceWith(newLibrary);
          }
          if (newStats) {
            const currentStats = document.querySelector('.video-stat-actions');
            if (currentStats) currentStats.replaceWith(newStats);
          }
          document.getElementById('videoFile').value = '';
          document.getElementById('fileName').textContent = '';
          window.showToast('Tải lên thành công', 'success');
        } catch {
          window.showToast('Tải lên thành công', 'success');
        }
      } else {
        var data=xhr.responseText?JSON.parse(xhr.responseText):{};
        window.showToast(data.message||'Tải lên thất bại','error');
      }
      document.getElementById('uploadLoading').classList.add('u-hidden'); document.getElementById('uploadLoading').style.display='none';
      document.getElementById('dropZone').classList.remove('uploading');
    };
    xhr.onerror = function(){ window.showToast('Lỗi mạng', 'error'); };
    xhr.send(formData);
  }


  function onDropDragOver(event) {
    event.preventDefault();
    document.getElementById('dropZone').classList.add('drag-over');
  }

  function onDropDragLeave(event) {
    event.preventDefault();
    document.getElementById('dropZone').classList.remove('drag-over');
  }

  function onDropFile(event) {
    event.preventDefault();
    document.getElementById('dropZone').classList.remove('drag-over');
    var file = event.dataTransfer?.files?.[0];
    if (!file) return;
    var input = document.getElementById('videoFile');
    var dt = new DataTransfer();
    dt.items.add(file);
    input.files = dt.files;
    onFileSelect(input);
  }

  function toggleDeleteMode() {
    document.querySelectorAll('.delete-col').forEach(el => el.style.display = 'table-cell');
    document.getElementById('deleteActions').style.display = 'inline-flex';
    document.getElementById('toggleDeleteModeBtn').style.display = 'none';
  }
  function cancelDeleteMode() {
    document.querySelectorAll('.delete-col').forEach(el => el.style.display = 'none');
    document.getElementById('deleteActions').style.display = 'none';
    document.getElementById('toggleDeleteModeBtn').style.display = 'inline-flex';
    document.querySelectorAll('.delete-check').forEach(cb => cb.checked = false);
  }
  function confirmBatchDelete() {
    const selected = Array.from(document.querySelectorAll('.delete-check:checked')).map(x => x.value);
    if (!selected.length) { window.showToast('Chọn ít nhất 1 video', 'error'); return; }
    const form = document.createElement('form'); form.method = 'post'; form.action = '/portal/videos/batch-delete';
    selected.forEach(id => { const i = document.createElement('input'); i.type='hidden'; i.name='videoIds'; i.value=id; form.appendChild(i); });
    document.body.appendChild(form); form.submit();
  }
</script>
