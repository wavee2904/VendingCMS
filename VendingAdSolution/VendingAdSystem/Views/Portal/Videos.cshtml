@model List<Media>
@{
    ViewData["Title"] = "Videos";
}

<div class="page-header">
  <div>
    <h1 class="page-title">Video Library</h1>
    <p class="page-subtitle">Upload một lần. Dùng lại cho playlist và schedule.</p>
  </div>
</div>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card surface" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h3 class="card-title">Tải lên video vào thư viện</h3>
    <div class="card-description">Chỉ nơi này nhận file mới.</div>
  </div>
  
  <style>
    .video-upload-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 1.5rem;
      align-items: start;
    }

    .device-select-panel {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--muted);
      padding: 0.75rem;
    }

    .device-select-body {
      max-height: 260px;
      overflow-y: auto;
      padding-right: 0.25rem;
    }

    .device-select-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.75rem;
      background: var(--background);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      cursor: pointer;
      margin-bottom: 0.5rem;
    }

    .device-select-item:last-child {
      margin-bottom: 0;
    }

    @@media (max-width: 768px) {
      .video-upload-grid {
        grid-template-columns: 1fr;
      }

      .device-select-body {
        max-height: 220px;
      }
    }
  </style>

  <div>
    <div class="upload-area" id="dropZone">
      <input type="file" id="videoFile" accept="video/*" onchange="onFileSelect(this)" />
      <div style="font-size: 2rem; margin-bottom: 0.5rem;">📤</div>
      <p class="text-muted">Click hoặc kéo file vào đây</p>
      <p class="text-sm text-muted">MP4, AVI, MOV (Max 50MB)</p>
      <p class="text-sm text-muted">Upload chỉ lưu vào thư viện video. Lịch phát chọn ở trang schedule.</p>
      <p id="fileName" style="color: var(--primary); font-weight: 500; margin-top: 0.5rem;"></p>
    </div>
    <div id="previewVideo" style="display: none; margin-top: 1rem;">
      <video id="videoPreview" controls style="width: 100%; max-height: 200px; border-radius: var(--radius);"></video>
    </div>
  </div>

  <div id="progressBar" style="background: var(--border); border-radius: 4px; height: 4px; margin-top: 1rem; display: none;">
    <div id="progressFill" style="height: 100%; background: var(--primary); width: 0%; transition: width 0.2s;"></div>
  </div>

  <div class="flex gap-2" style="margin-top: 1rem; flex-wrap: wrap;">
    <button class="btn btn-primary" id="uploadBtn" onclick="doUpload()" disabled>Tải lên</button>
  </div>
</div>

<div class="section" style="margin-top: 2rem;">
  <div class="card surface">
    <div class="card-header flex items-center justify-between" style="gap: 1rem; flex-wrap: wrap;">
      <div>
        <h3 class="card-title">Danh sách video (@Model.Count)</h3>
        <div class="card-description">Chọn nhiều để xóa, hoặc mở playlist/schedule từ kho này.</div>
      </div>
      <div class="page-actions">
        <button type="button" class="btn btn-secondary" id="toggleDeleteModeBtn" onclick="toggleDeleteMode()">Xóa Video</button>
      </div>
      <div id="deleteActions" class="page-actions" style="display:none;">
        <button type="button" class="btn btn-secondary" onclick="cancelDeleteMode()">Hủy</button>
        <button type="button" class="btn btn-danger" onclick="confirmBatchDelete()">Xác nhận xóa</button>
      </div>
    </div>
    
    @if (!Model.Any())
    {
      <div class="empty-state">
        <div style="font-size: 3rem; margin-bottom: 0.75rem;">📁</div>
        <p>Chưa có video nào</p>
      </div>
    }
    else
    {
      <div class="table-wrapper">
        <table class="table">
          <thead>
            <tr>
              <th>Tên video</th>
              <th>Dung lượng</th>
              <th>Ngày upload</th>
              <th>Playlist</th>
              <th style="width: 56px; display:none;" class="delete-col">Chọn</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var video in Model)
            {
              <tr>
                <td>@video.FileName</td>
                <td>@(video.FileSize / 1024 / 1024) MB</td>
                <td>@TimeZoneInfo.ConvertTimeFromUtc(video.UploadedAt, TimeZoneInfo.FindSystemTimeZoneById("SE Asia Standard Time")).ToString("yyyy-MM-dd")</td>
                <td>
                  @foreach (var playlist in video.PlaylistItems.Select(i => i.Playlist).DistinctBy(p => p.Id).OrderBy(p => p.Name))
                  {
                    <span class="badge badge-primary" style="margin-right: 0.5rem;">@playlist.Name</span>
                  }
                </td>
                <td class="delete-col" style="display:none;">
                  <input type="checkbox" class="delete-check" value="@video.Id" />
                </td>
                <td>
                  <form method="post" action="/portal/videos/delete">
                    <input type="hidden" name="videoId" value="@video.Id" />
                    <button type="submit" class="action-btn action-btn-danger" onclick="return confirm('Bạn có chắc muốn xóa video này?')">🗑️</button>
                  </form>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>
</div>

<script>
  var userId = @Context.Session.GetInt32("UserId");
  var deleteMode = false;

  function onFileSelect(input) {
    var file = input.files[0];
    if (!file) return;

    if (file.size > 50 * 1024 * 1024) {
      alert('File phải nhỏ hơn 50MB');
      input.value = '';
      return;
    }

    document.getElementById('fileName').textContent = file.name;
    document.getElementById('uploadBtn').disabled = false;

    var video = document.getElementById('videoPreview');
    video.src = URL.createObjectURL(file);
    document.getElementById('previewVideo').style.display = 'block';
  }

  async function doUpload() {
    var file = document.getElementById('videoFile').files[0];
    if (!file) {
      alert('Chọn file video');
      return;
    }

    var btn = document.getElementById('uploadBtn');
    btn.disabled = true;
    btn.textContent = 'Đang upload...';

    var formData = new FormData();
    formData.append('file', file);
    formData.append('userId', userId);

    var xhr = new XMLHttpRequest();
    xhr.open('POST', '/api/portal/upload');

    xhr.upload.onprogress = function(e) {
      if (e.lengthComputable) {
        var percent = Math.round(e.loaded / e.total * 100);
        document.getElementById('progressFill').style.width = percent + '%';
        document.getElementById('progressBar').style.display = 'block';
      }
    };

    xhr.onload = function() {
      btn.disabled = false;
      btn.textContent = 'Upload Video';
      if (xhr.status === 200) {
        location.reload();
      } else {
        var data = JSON.parse(xhr.responseText);
        alert(data.message || 'Tải lên thất bại');
      }
    };

    xhr.onerror = function() {
      btn.disabled = false;
      btn.textContent = 'Upload Video';
      alert('Lỗi mạng');
    };

    xhr.send(formData);
  }

  function toggleDeleteMode() {
    deleteMode = true;
    document.querySelectorAll('.delete-col').forEach(el => el.style.display = 'table-cell');
    document.getElementById('deleteActions').style.display = 'flex';
    document.getElementById('toggleDeleteModeBtn').style.display = 'none';
    document.querySelectorAll('form[action="/portal/videos/delete"]').forEach(f => f.style.display = 'none');
  }

  function cancelDeleteMode() {
    deleteMode = false;
    document.querySelectorAll('.delete-col').forEach(el => el.style.display = 'none');
    document.getElementById('deleteActions').style.display = 'none';
    document.getElementById('toggleDeleteModeBtn').style.display = 'inline-flex';
    document.querySelectorAll('.delete-check').forEach(cb => cb.checked = false);
    document.querySelectorAll('form[action="/portal/videos/delete"]').forEach(f => f.style.display = 'block');
  }

  function confirmBatchDelete() {
    const selected = Array.from(document.querySelectorAll('.delete-check:checked')).map(x => x.value);
    if (selected.length === 0) {
      alert('Chọn ít nhất 1 video');
      return;
    }

    const form = document.createElement('form');
    form.method = 'post';
    form.action = '/portal/videos/batch-delete';
    selected.forEach(id => {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'videoIds';
      input.value = id;
      form.appendChild(input);
    });
    document.body.appendChild(form);
    form.submit();
  }
</script>
