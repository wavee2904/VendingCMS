@model List<Media>
@{
    var devices = (List<Device>)ViewBag.Devices;
    ViewData["Title"] = "Videos";
}

<div class="page-header">
  <h1 class="page-title">Quản lý Video</h1>
</div>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card">
  <div class="card-header">
    <h3 class="card-title">Tải lên Video</h3>
  </div>
  
  <style>
    .video-upload-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 1.5rem;
      align-items: start;
    }

    .device-select-panel {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--muted);
      padding: 0.75rem;
    }

    .device-select-body {
      max-height: 260px;
      overflow-y: auto;
      padding-right: 0.25rem;
    }

    .device-select-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.75rem;
      background: var(--background);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      cursor: pointer;
      margin-bottom: 0.5rem;
    }

    .device-select-item:last-child {
      margin-bottom: 0;
    }

    @@media (max-width: 768px) {
      .video-upload-grid {
        grid-template-columns: 1fr;
      }

      .device-select-body {
        max-height: 220px;
      }
    }
  </style>

  <div class="video-upload-grid">
    <div>
      <div class="upload-area" id="dropZone">
        <input type="file" id="videoFile" accept="video/*" onchange="onFileSelect(this)" />
        <div style="font-size: 2rem; margin-bottom: 0.5rem;">📤</div>
        <p class="text-muted">Click hoặc kéo file vào đây</p>
        <p class="text-sm text-muted">MP4, AVI, MOV (Max 50MB)</p>
        <p id="fileName" style="color: var(--primary); font-weight: 500; margin-top: 0.5rem;"></p>
      </div>
      <div id="previewVideo" style="display: none; margin-top: 1rem;">
        <video id="videoPreview" controls style="width: 100%; max-height: 200px; border-radius: var(--radius);"></video>
      </div>
    </div>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <div>
        <label class="form-label">Chọn thiết bị</label>
        <div class="device-select-panel">
          <div class="device-select-body">
            @foreach (var device in devices)
            {
              <label class="device-select-item">
                <input type="checkbox" name="selectedDevices" value="@device.Id" style="accent-color: var(--primary);" />
                <span class="text-sm">@device.DeviceCode - @device.Location</span>
              </label>
            }
          </div>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div class="form-group">
          <label class="form-label">Ngày bắt đầu</label>
          <input type="date" id="startDate" class="form-input" />
        </div>
        <div class="form-group">
          <label class="form-label">Ngày kết thúc</label>
          <input type="date" id="endDate" class="form-input" />
        </div>
      </div>
    </div>
  </div>

  <div id="progressBar" style="background: var(--border); border-radius: 4px; height: 4px; margin-top: 1rem; display: none;">
    <div id="progressFill" style="height: 100%; background: var(--primary); width: 0%; transition: width 0.2s;"></div>
  </div>

  <button class="btn btn-primary" id="uploadBtn" onclick="doUpload()" disabled style="margin-top: 1rem;">Tải lên Video</button>
</div>

<div class="section" style="margin-top: 2rem;">
  <div class="card" style="background: var(--muted);">
    <div class="card-header">
      <h3 class="card-title">Danh sách Video (@Model.Count)</h3>
    </div>
    
    @if (!Model.Any())
    {
      <div class="empty-state">
        <div style="font-size: 3rem; margin-bottom: 0.75rem;">📁</div>
        <p>Chưa có video nào</p>
      </div>
    }
    else
    {
      <div class="table-wrapper">
        <table class="table">
          <thead>
            <tr>
              <th>Tên video</th>
              <th>Dung lượng</th>
              <th>Ngày upload</th>
              <th>Thiết bị</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var video in Model)
            {
              <tr>
                <td>@video.FileName</td>
                <td>@(video.FileSize / 1024 / 1024) MB</td>
                <td>@video.UploadedAt.ToString("yyyy-MM-dd")</td>
                <td>
                  @foreach (var campaign in video.Campaigns)
                  {
                    <span class="badge badge-secondary" style="margin-right: 0.5rem;">@campaign.Device.DeviceCode</span>
                  }
                </td>
                <td>
                  <form method="post" action="/portal/videos/delete">
                    <input type="hidden" name="videoId" value="@video.Id" />
                    <button type="submit" class="action-btn action-btn-danger" onclick="return confirm('Bạn có chắc muốn xóa video này?')">🗑️</button>
                  </form>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>
</div>

<script>
  var userId = @Context.Session.GetInt32("UserId");

  function onFileSelect(input) {
    var file = input.files[0];
    if (!file) return;

    if (file.size > 50 * 1024 * 1024) {
      alert('File phải nhỏ hơn 50MB');
      input.value = '';
      return;
    }

    document.getElementById('fileName').textContent = file.name;
    document.getElementById('uploadBtn').disabled = false;

    var video = document.getElementById('videoPreview');
    video.src = URL.createObjectURL(file);
    document.getElementById('previewVideo').style.display = 'block';
  }

  async function doUpload() {
    var file = document.getElementById('videoFile').files[0];
    if (!file) {
      alert('Chọn file video');
      return;
    }

    var startDate = document.getElementById('startDate').value;
    var endDate = document.getElementById('endDate').value;

    var selectedDevices = Array.from(document.querySelectorAll('input[name="selectedDevices"]:checked'))
      .map(cb => cb.value);

    if (selectedDevices.length === 0) {
      alert('Chọn ít nhất 1 thiết bị');
      return;
    }

    if (!startDate || !endDate) {
      alert('Chọn ngày bắt đầu và kết thúc');
      return;
    }

    var btn = document.getElementById('uploadBtn');
    btn.disabled = true;
    btn.textContent = 'Đang upload...';

    var formData = new FormData();
    formData.append('file', file);
    formData.append('userId', userId);
    formData.append('startDate', startDate);
    formData.append('endDate', endDate);
    selectedDevices.forEach(d => formData.append('deviceIds', d));

    var xhr = new XMLHttpRequest();
    xhr.open('POST', '/api/portal/upload');

    xhr.upload.onprogress = function(e) {
      if (e.lengthComputable) {
        var percent = Math.round(e.loaded / e.total * 100);
        document.getElementById('progressFill').style.width = percent + '%';
        document.getElementById('progressBar').style.display = 'block';
      }
    };

    xhr.onload = function() {
      btn.disabled = false;
      btn.textContent = 'Upload Video';
      if (xhr.status === 200) {
        location.reload();
      } else {
        var data = JSON.parse(xhr.responseText);
        alert(data.message || 'Tải lên thất bại');
      }
    };

    xhr.onerror = function() {
      btn.disabled = false;
      btn.textContent = 'Upload Video';
      alert('Lỗi mạng');
    };

    xhr.send(formData);
  }
</script>
