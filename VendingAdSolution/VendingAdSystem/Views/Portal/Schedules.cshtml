<script>
  let createMode = 'schedule';
  let sourceTab = 'media';
  let selectedPlaylistId = null;
  let draggedPlaylistItem = null;
  let draggedScheduleItem = null;
  const scheduleDraft = @Html.Raw(string.IsNullOrWhiteSpace(scheduleDraftJson) ? "null" : scheduleDraftJson);

  function openCreateSchedule(mode) {
    createMode = mode || 'schedule';
    document.getElementById('scheduleActionType').value = createMode;
    document.getElementById('createPanelIcon').innerHTML = createMode === 'immediate' ? '<i class="bi bi-play-fill"></i>' : '<i class="bi bi-calendar-plus"></i>';
    document.getElementById('createPanelTitle').textContent = createMode === 'immediate' ? 'Tạo danh sách phát ngay' : 'Tạo lịch phát video';
    document.getElementById('createPanelDescription').textContent = createMode === 'immediate' ? 'Phát ngay' : 'Theo lịch';
    document.getElementById('scheduleSubmitBtn').innerHTML = createMode === 'immediate'
      ? '<i class="bi bi-play-fill"></i>Phát'
      : '<i class="bi bi-calendar-check"></i>Lên lịch';

    document.getElementById('createSchedulePanel').style.display = 'block';
    setDateRange('today');
    if (createMode === 'immediate') {
      setImmediateTimeRange();
    } else if (!document.getElementById('startTime').value) {
      setTimeRange('morning');
    }
  }

  function restoreScheduleDraft() {
    if (!scheduleDraft) return;

    const form = document.getElementById('scheduleCreateForm');
    document.getElementById('createSchedulePanel').style.display = 'block';
    createMode = scheduleDraft.actionType || 'schedule';
    document.getElementById('scheduleActionType').value = createMode;
    document.getElementById('createPanelIcon').innerHTML = createMode === 'immediate' ? '<i class="bi bi-play-fill"></i>' : '<i class="bi bi-calendar-plus"></i>';
    document.getElementById('createPanelTitle').textContent = createMode === 'immediate' ? 'Tạo danh sách phát ngay' : 'Tạo lịch phát video';
    document.getElementById('createPanelDescription').textContent = createMode === 'immediate' ? 'Phát ngay' : 'Theo lịch';
    document.getElementById('scheduleSubmitBtn').innerHTML = createMode === 'immediate'
      ? '<i class="bi bi-play-fill"></i>Phát'
      : '<i class="bi bi-calendar-check"></i>Lên lịch';

    form.querySelector('[name="Name"]').value = scheduleDraft.Name || '';
    document.getElementById('startDate').value = scheduleDraft.startDate || '';
    document.getElementById('endDate').value = scheduleDraft.endDate || '';
    document.getElementById('startTime').value = scheduleDraft.startTime || '';
    document.getElementById('endTime').value = scheduleDraft.endTime || '';

    const draftSourceTab = scheduleDraft.sourceTab || 'media';
    sourceTab = draftSourceTab;
    document.getElementById('scheduleSourceTab').value = draftSourceTab;
    switchSourceTab(draftSourceTab);

    const draftDeviceIds = new Set((scheduleDraft.deviceIds || []).map(String));
    document.querySelectorAll('#scheduleCreateForm input[name="DeviceIds"]').forEach(input => {
      input.checked = draftDeviceIds.has(input.value);
    });

    if (draftSourceTab === 'playlist') {
      selectedPlaylistId = scheduleDraft.selectedSourcePlaylistId || null;
      document.getElementById('selectedSourcePlaylistId').value = selectedPlaylistId || '';
      if (selectedPlaylistId) {
        selectPlaylistSource(selectedPlaylistId);
        const selectedList = document.getElementById('playlistPreview-' + selectedPlaylistId);
        const draftMediaOrder = (scheduleDraft.mediaIds || []).map(String);
        draftMediaOrder.forEach(mediaId => {
          const item = selectedList?.querySelector('.playlist-preview-item[data-media-id="' + mediaId + '"]');
          if (item) selectedList.appendChild(item);
        });
        if (selectedList) syncPlaylistOrderNumbers(selectedList);
      }
    } else {
      const draftMediaIds = new Set((scheduleDraft.mediaIds || []).map(String));
      document.querySelectorAll('#scheduleCreateForm input[name="MediaIds"]').forEach(input => {
        input.checked = draftMediaIds.has(input.value);
      });
    }
  }

  function closeCreateSchedule() {
    document.getElementById('createSchedulePanel').style.display = 'none';
  }

  function setScheduleAction(value) {
    document.getElementById('scheduleActionType').value = value;
  }

  function setTodayDateRange() {
    const now = new Date();
    const date = now.toISOString().slice(0, 10);
    document.getElementById('startDate').value = date;
    document.getElementById('endDate').value = date;
  }

  function addDays(value, days) {
    const next = new Date(value.getTime());
    next.setDate(next.getDate() + days);
    return next;
  }

  function formatDate(date) {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    return year + '-' + month + '-' + day;
  }

  function setDateRange(mode) {
    const today = new Date();
    if (mode === 'today') {
      document.getElementById('startDate').value = formatDate(today);
      document.getElementById('endDate').value = formatDate(today);
      return;
    }

    if (mode === '7d') {
      document.getElementById('startDate').value = formatDate(today);
      document.getElementById('endDate').value = formatDate(addDays(today, 6));
      return;
    }

    if (mode === '30d') {
      document.getElementById('startDate').value = formatDate(today);
      document.getElementById('endDate').value = formatDate(addDays(today, 29));
    }
  }

  function setTimeRange(mode) {
    const pairs = {
      'all-day': ['00:00', '23:59'],
      'morning': ['06:00', '11:59'],
      'afternoon': ['12:00', '17:59'],
      'evening': ['18:00', '23:59']
    };
    const pair = pairs[mode];
    if (!pair) return;
    document.getElementById('startTime').value = pair[0];
    document.getElementById('endTime').value = pair[1];
  }

  function setImmediateTimeRange() {
    const now = new Date();
    const hours = String(now.getHours()).padStart(2, '0');
    const minutes = String(now.getMinutes()).padStart(2, '0');
    document.getElementById('startTime').value = hours + ':' + minutes;
    document.getElementById('endTime').value = '23:59';
  }

  function switchSourceTab(tab) {
    sourceTab = tab;
    document.getElementById('scheduleSourceTab').value = tab;
    document.getElementById('mediaSourcePanel').style.display = tab === 'media' ? 'block' : 'none';
    document.getElementById('playlistSourcePanel').style.display = tab === 'playlist' ? 'block' : 'none';
    document.getElementById('mediaTabBtn').classList.toggle('active', tab === 'media');
    document.getElementById('playlistTabBtn').classList.toggle('active', tab === 'playlist');

    document.querySelectorAll('input[data-generated="playlist-media"]').forEach(input => input.remove());
    if (tab === 'media') {
      selectedPlaylistId = null;
      document.getElementById('selectedSourcePlaylistId').value = '';
      document.querySelectorAll('.playlist-choice').forEach(btn => btn.classList.remove('active'));
      document.querySelectorAll('.playlist-preview-list').forEach(list => list.style.display = 'none');
      document.getElementById('playlistPreviewEmpty').style.display = 'block';
    } else {
      document.querySelectorAll('#mediaSourcePanel input[type="checkbox"]').forEach(cb => cb.checked = false);
    }
  }

  function selectPlaylistSource(playlistId) {
    selectedPlaylistId = playlistId;
    document.getElementById('selectedSourcePlaylistId').value = playlistId;
    document.querySelectorAll('.playlist-choice').forEach(btn => btn.classList.toggle('active', parseInt(btn.dataset.playlistId) === playlistId));
    document.querySelectorAll('.playlist-preview-list').forEach(list => list.style.display = 'none');
    document.getElementById('playlistPreviewEmpty').style.display = 'none';
    const selectedList = document.getElementById('playlistPreview-' + playlistId);
    if (selectedList) selectedList.style.display = 'grid';
  }

  function syncPlaylistOrderNumbers(list) {
    list.querySelectorAll('.playlist-preview-item').forEach((item, index) => {
      item.querySelector('.playlist-preview-order').textContent = index + 1;
    });
  }

  function initPlaylistDrag() {
    document.querySelectorAll('.playlist-preview-item').forEach(item => {
      item.addEventListener('dragstart', function (e) {
        draggedPlaylistItem = this;
        this.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
      });

      item.addEventListener('dragend', function () {
        this.classList.remove('dragging');
        draggedPlaylistItem = null;
        syncPlaylistOrderNumbers(this.parentElement);
      });

      item.addEventListener('dragover', function (e) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
      });

      item.addEventListener('drop', function (e) {
        e.preventDefault();
        if (!draggedPlaylistItem || draggedPlaylistItem === this) return;

        const container = this.parentElement;
        const items = Array.from(container.querySelectorAll('.playlist-preview-item'));
        const fromIndex = items.indexOf(draggedPlaylistItem);
        const toIndex = items.indexOf(this);
        if (fromIndex < toIndex) {
          container.insertBefore(draggedPlaylistItem, this.nextSibling);
        } else {
          container.insertBefore(draggedPlaylistItem, this);
        }
        syncPlaylistOrderNumbers(container);
      });
    });
  }

  function syncScheduleOrderNumbers(container) {
    container.querySelectorAll('.schedule-item-row').forEach((row, index) => {
      const orderCell = row.querySelector('.schedule-order-cell span:last-child');
      if (orderCell) orderCell.textContent = '#' + (index + 1);
    });
  }

  function saveScheduleOrder(container) {
    const firstRow = container.querySelector('.schedule-item-row');
    if (!firstRow) return;

    const scheduleId = parseInt(firstRow.dataset.scheduleId);
    const updates = Array.from(container.querySelectorAll('.schedule-item-row')).map((row, orderIndex) => ({
      scheduleItemId: parseInt(row.dataset.itemId),
      orderIndex
    }));

    fetch('/portal/schedules/update-item-order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': window.getRequestVerificationToken?.() || '' },
      body: JSON.stringify({ scheduleId: scheduleId, updates: updates })
    }).then(r => {
      if (!r.ok) location.reload();
    }).catch(() => location.reload());
  }

  function initScheduleDrag() {
    document.querySelectorAll('.schedule-item-row').forEach(row => {
      row.addEventListener('dragstart', function (e) {
        draggedScheduleItem = this;
        this.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
      });

      row.addEventListener('dragend', function () {
        this.classList.remove('dragging');
        draggedScheduleItem = null;
      });

      row.addEventListener('dragover', function (e) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
      });

      row.addEventListener('drop', function (e) {
        e.preventDefault();
        if (!draggedScheduleItem || draggedScheduleItem === this) return;

        const container = this.parentElement;
        const rows = Array.from(container.querySelectorAll('.schedule-item-row'));
        const fromIndex = rows.indexOf(draggedScheduleItem);
        const toIndex = rows.indexOf(this);
        if (fromIndex < toIndex) {
          container.insertBefore(draggedScheduleItem, this.nextSibling);
        } else {
          container.insertBefore(draggedScheduleItem, this);
        }

        syncScheduleOrderNumbers(container);
        saveScheduleOrder(container);
      });
    });
  }

  document.getElementById('scheduleCreateForm').addEventListener('submit', function (e) {
    document.querySelectorAll('input[data-generated="playlist-media"]').forEach(input => input.remove());
    document.getElementById('scheduleSourceTab').value = sourceTab;

    if (sourceTab !== 'playlist') return;

    const selectedList = selectedPlaylistId ? document.getElementById('playlistPreview-' + selectedPlaylistId) : null;
    if (!selectedList) {
      e.preventDefault();
      window.showToast('Chọn playlist trước khi tạo schedule.', 'error');
      return;
    }

    const mediaIds = Array.from(selectedList.querySelectorAll('.playlist-preview-item')).map(item => item.dataset.mediaId);
    if (!mediaIds.length) {
      e.preventDefault();
      window.showToast('Danh sách phát chưa có video.', 'error');
      return;
    }

    mediaIds.forEach(mediaId => {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'MediaIds';
      input.value = mediaId;
      input.dataset.generated = 'playlist-media';
      this.appendChild(input);
    });
  });

  initPlaylistDrag();
  initScheduleDrag();
  restoreScheduleDraft();

  function openScheduleDetail(id) {
    document.getElementById('scheduleDetail-' + id).style.display = 'flex';
  }

  function closeScheduleDetail(id) {
    document.getElementById('scheduleDetail-' + id).style.display = 'none';
  }

</script>

</div>
