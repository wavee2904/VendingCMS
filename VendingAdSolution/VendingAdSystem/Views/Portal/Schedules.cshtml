@model List<PlaybackSchedule>
@{
    var devices = (List<Device>)ViewBag.Devices;
    var playlists = (List<Playlist>)ViewBag.Playlists;
    var medias = (List<Media>)ViewBag.Medias;
    var scheduleDraftJson = ViewBag.ScheduleDraftJson as string ?? string.Empty;
    var vietnamNow = DateTime.UtcNow.AddHours(7);
    ViewData["Title"] = "Lịch phát";

    string VietnamDate(DateTime utcDate) => utcDate.AddHours(7).ToString("dd/MM/yyyy");
    string DateRangeText(PlaybackSchedule schedule) => VietnamDate(schedule.StartDate) == VietnamDate(schedule.EndDate) ? VietnamDate(schedule.StartDate) : $"{VietnamDate(schedule.StartDate)} - {VietnamDate(schedule.EndDate)}";
    string TimeRangeText(PlaybackSchedule schedule) => $"{schedule.StartTime:hh\\:mm} - {schedule.EndTime:hh\\:mm}";
    DateTime LocalScheduleStart(PlaybackSchedule schedule) => schedule.StartDate.AddHours(7).Date.Add(schedule.StartTime);
    DateTime LocalScheduleEnd(PlaybackSchedule schedule) => schedule.EndDate.AddHours(7).Date.Add(schedule.EndTime);
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

<div class="schedules-page">
  <div class="schedule-mode-grid schedule-mode-grid-modern u-mb-15">
    <button type="button" class="schedule-mode-card card surface fx-card" onclick="openCreateSchedule('immediate')">
      <span class="schedule-mode-icon"><i class="bi bi-play-fill"></i></span>
      <span>
        <strong>Phát nội dung ngay bây giờ</strong>
        <small>Chọn nội dung, thiết bị và bắt đầu phát ngay lập tức.</small>
      </span>
    </button>
    <button type="button" class="schedule-mode-card card surface fx-card" onclick="openCreateSchedule('schedule')">
      <span class="schedule-mode-icon"><i class="bi bi-calendar-event"></i></span>
      <span>
        <strong>Tạo lịch phát mới</strong>
        <small>Đặt ngày giờ và nội dung để tự động phát theo lịch.</small>
      </span>
    </button>
  </div>
<section class="schedule-create-panel u-hidden u-mb-15" id="createSchedulePanel">
  <div class="schedule-builder-head">
    <div class="schedule-builder-title">
      <span class="schedule-builder-icon" id="createPanelIcon"><i class="bi bi-calendar-plus"></i></span>
      <div>
        <h3 id="createPanelTitle">Tạo schedule</h3>
        <p id="createPanelDescription">Theo lịch</p>
      </div>
    </div>
    <button type="button" class="icon-btn schedule-builder-close" onclick="closeCreateSchedule()" aria-label="Đóng"><i class="bi bi-x-lg"></i></button>
  </div>

  <form method="post" action="/portal/schedules/create" id="scheduleCreateForm" class="schedule-create-form">
    @Html.AntiForgeryToken()
    <input type="hidden" name="actionType" id="scheduleActionType" value="schedule" />
    <input type="hidden" name="sourceTab" id="scheduleSourceTab" value="media" />
    <input type="hidden" name="selectedSourcePlaylistId" id="selectedSourcePlaylistId" />

    <div class="schedule-builder-grid">
      <div class="schedule-builder-main">
        <section class="schedule-builder-section schedule-info-section">
          <div class="schedule-section-head">
            <span><i class="bi bi-info-circle"></i></span>
            <h4>Thông tin phát</h4>
          </div>

          <div class="form-group schedule-name-field">
            <label class="form-label">Tên schedule</label>
            <input class="form-input" name="Name" placeholder="VD: Quầy A - khung giờ trưa" required />
          </div>

          <div class="schedule-time-layout">
            <div class="schedule-fieldset">
              <div class="schedule-fieldset-head">
                <strong><i class="bi bi-calendar3"></i>Khung ngày</strong>
                <div class="schedule-preset-row">
                  <button type="button" class="schedule-preset" onclick="setDateRange('today')">Hôm nay</button>
                  <button type="button" class="schedule-preset" onclick="setDateRange('7d')">7 ngày</button>
                  <button type="button" class="schedule-preset" onclick="setDateRange('30d')">30 ngày</button>
                </div>
              </div>
              <div class="two-field-grid">
                <div class="form-group">
                  <label class="form-label">Bắt đầu</label>
                  <input class="form-input" type="date" name="StartDate" id="startDate" required />
                </div>
                <div class="form-group">
                  <label class="form-label">Kết thúc</label>
                  <input class="form-input" type="date" name="EndDate" id="endDate" required />
                </div>
              </div>
            </div>

            <div class="schedule-fieldset">
              <div class="schedule-fieldset-head">
                <strong><i class="bi bi-clock"></i>Khung giờ</strong>
                <div class="schedule-preset-row">
                  <button type="button" class="schedule-preset" onclick="setTimeRange('all-day')">Cả ngày</button>
                  <button type="button" class="schedule-preset" onclick="setTimeRange('morning')">Sáng</button>
                  <button type="button" class="schedule-preset" onclick="setTimeRange('afternoon')">Chiều</button>
                  <button type="button" class="schedule-preset" onclick="setTimeRange('evening')">Tối</button>
                </div>
              </div>
              <div class="two-field-grid">
                <div class="form-group">
                  <label class="form-label">Bắt đầu</label>
                  <input class="form-input" type="time" name="StartTime" id="startTime" required />
                </div>
                <div class="form-group">
                  <label class="form-label">Kết thúc</label>
                  <input class="form-input" type="time" name="EndTime" id="endTime" required />
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="schedule-builder-section schedule-source-section">
          <div class="schedule-section-head schedule-section-head-split">
            <div>
              <span><i class="bi bi-collection-play"></i></span>
              <h4>Nguồn video</h4>
            </div>
            <div class="source-tabs">
              <button type="button" class="source-tab active" id="mediaTabBtn" onclick="switchSourceTab('media')"><i class="bi bi-film"></i>Video từ kho</button>
              <button type="button" class="source-tab" id="playlistTabBtn" onclick="switchSourceTab('playlist')"><i class="bi bi-card-checklist"></i>Danh sách phát</button>
            </div>
          </div>

          <div id="mediaSourcePanel" class="source-panel">
            <div class="schedule-select-panel schedule-media-panel">
              @foreach (var m in medias)
              {
                <label class="schedule-select-item">
                  <input type="checkbox" name="MediaIds" value="@m.Id" data-source="media" />
                  <span class="schedule-select-icon"><i class="bi bi-play-btn"></i></span>
                  <div>
                    <div class="schedule-select-title">@m.FileName</div>
                    <div class="schedule-select-subtitle">@((m.FileSize / 1024 / 1024).ToString()) MB</div>
                  </div>
                </label>
              }
            </div>
          </div>

          <div id="playlistSourcePanel" class="source-panel u-hidden">
            <input type="hidden" id="playlistSelect" />
            <div class="playlist-choice-grid">
              @foreach (var p in playlists)
              {
                var items = p.Items.OrderBy(i => i.OrderIndex).ToList();
                <button type="button" class="playlist-choice" data-playlist-id="@p.Id" onclick="selectPlaylistSource(@p.Id)">
                  <strong>@p.Name</strong>
                  <span>@items.Count video(s)</span>
                </button>
              }
            </div>

            <div class="playlist-preview" id="playlistPreviewEmpty">
              Chọn playlist để xem nội dung.
            </div>

            @foreach (var p in playlists)
            {
              var items = p.Items.OrderBy(i => i.OrderIndex).ToList();
              <div class="playlist-preview-list u-hidden" id="playlistPreview-@p.Id" data-playlist-id="@p.Id">
                @foreach (var item in items)
                {
                  <div class="playlist-preview-item" draggable="true" data-media-id="@item.MediaId">
                    <span class="drag-handle"><i class="bi bi-grip-vertical"></i></span>
                    <span class="playlist-preview-order">@(item.OrderIndex + 1)</span>
                    <div>
                      <div class="schedule-select-title">@item.Media.FileName</div>
                      <div class="schedule-select-subtitle">@((item.Media.FileSize / 1024 / 1024).ToString()) MB</div>
                    </div>
                  </div>
                }
              </div>
            }
          </div>
        </section>
      </div>

      <aside class="schedule-builder-side">
        <section class="schedule-builder-section schedule-device-section">
          <div class="schedule-section-head schedule-section-head-split">
            <div>
              <span><i class="bi bi-display"></i></span>
              <h4>Thiết bị phát</h4>
            </div>
            <strong class="schedule-count-chip">@devices.Count</strong>
          </div>

          <div class="schedule-select-panel schedule-device-panel">
            @foreach (var d in devices)
            {
              <label class="schedule-select-item">
                <input type="checkbox" name="DeviceIds" value="@d.Id" />
                <span class="schedule-select-icon"><i class="bi bi-display"></i></span>
                <div>
                  <div class="schedule-select-title">@d.DeviceCode</div>
                  <div class="schedule-select-subtitle">@((d.Location ?? "Chưa có vị trí"))</div>
                </div>
              </label>
            }
          </div>
        </section>

        <div class="schedule-builder-actions">
          <button class="btn btn-primary fx-btn schedule-submit-btn" type="submit" id="scheduleSubmitBtn"><i class="bi bi-calendar-check"></i>Lên lịch</button>
        </div>
      </aside>
    </div>
  </form>
</section>

@if (!Model.Any())
{
  <div class="schedule-empty-state">
    <div class="schedule-empty-icon"><i class="bi bi-calendar3"></i><span>31</span></div>
    <h2>Chưa có lịch phát nào</h2>
    <p>Tạo lịch phát để lên lịch phát nội dung cho thiết bị.</p>
    <div class="schedule-empty-actions">
      <button class="btn btn-primary fx-btn" type="button" onclick="openCreateSchedule('immediate')">Phát ngay</button>
      <button class="btn btn-secondary fx-soft" type="button" onclick="openCreateSchedule('schedule')">Tạo lịch phát</button>
    </div>
    <div class="schedule-tip-box">
      <strong>Bạn có biết?</strong>
      <span>Lịch phát có thể lặp lại theo ngày, tuần, tháng hoặc theo khung giờ cố định.</span>
    </div>
  </div>
}
else
{
  <div class="schedule-list-header">
    <div>
      <h2 class="section-title u-mb-025">Lịch phát hiện có</h2>
      <p class="text-sm text-muted">Theo dõi trạng thái, thiết bị và nội dung của từng lịch phát.</p>
    </div>
    <div class="schedule-count">@Model.Count schedule</div>
  </div>

  <div class="schedule-list">
    @foreach (var s in Model)
    {
      var visibleDevices = s.Devices.OrderBy(x => x.Device.DeviceCode).Take(3).ToList();
      var remainingDevices = Math.Max(0, s.Devices.Count - visibleDevices.Count);
      var visibleItems = s.Items.OrderBy(i => i.OrderIndex).Take(3).ToList();
      var remainingItems = Math.Max(0, s.Items.Count - visibleItems.Count);
      var scheduleStart = LocalScheduleStart(s);
      var scheduleEnd = LocalScheduleEnd(s);
      var scheduleState = s.IsActive && vietnamNow >= scheduleStart && vietnamNow <= scheduleEnd
        ? "playing"
        : vietnamNow <= scheduleEnd
          ? "upcoming"
          : "past";
      var scheduleStateLabel = scheduleState switch
      {
        "playing" => "Đang phát",
        "upcoming" => "Chờ tới lịch phát",
        _ => "Đã qua lịch phát"
      };
      var scheduleStateDetail = scheduleState switch
      {
        "playing" => s.IsImmediate ? "Phát ngay" : "Trong khung giờ",
        "upcoming" => $"Bắt đầu {scheduleStart:dd/MM HH:mm}",
        _ => $"Kết thúc {scheduleEnd:dd/MM HH:mm}"
      };
      var scheduleStateIcon = scheduleState switch
      {
        "playing" => "bi-broadcast-pin",
        "upcoming" => "bi-hourglass-split",
        _ => "bi-calendar-x"
      };

      <article class="schedule-live-card schedule-state-@scheduleState">
        <div class="schedule-live-status">
          <span class="schedule-status-dot"><i class="bi @scheduleStateIcon"></i></span>
          <strong>@scheduleStateLabel</strong>
          <small>@scheduleStateDetail</small>
        </div>

        <div class="schedule-live-body">
          <div class="schedule-live-main-row">
            <div class="schedule-live-title-block">
              <div class="schedule-live-type">
                <i class="bi @(s.IsImmediate ? "bi-lightning-charge" : "bi-calendar-event")"></i>
                @(s.IsImmediate ? "Phát ngay" : "Lịch thường")
              </div>
              <h3>@s.Name</h3>
            </div>

            <div class="schedule-live-actions">
              <button type="button" class="schedule-action-btn primary" onclick="openScheduleDetail(@s.Id)"><i class="bi bi-sliders"></i>Chi tiết</button>
              <form method="post" action="/portal/schedules/toggle">
                @Html.AntiForgeryToken()
                <input type="hidden" name="scheduleId" value="@s.Id" />
                <button class="schedule-action-btn" type="submit"><i class="bi @(s.IsActive ? "bi-pause-fill" : "bi-play-fill")"></i>@(s.IsActive ? "Tắt" : "Bật")</button>
              </form>
              <form method="post" action="/portal/schedules/delete" onsubmit="return confirm('Xóa schedule?')">
                @Html.AntiForgeryToken()
                <input type="hidden" name="scheduleId" value="@s.Id" />
                <button class="schedule-action-btn danger" type="submit"><i class="bi bi-trash"></i>Xóa</button>
              </form>
            </div>
          </div>

          <div class="schedule-live-facts">
            <div class="schedule-fact">
              <span><i class="bi bi-calendar3"></i></span>
              <div><small>Ngày phát</small><strong>@DateRangeText(s)</strong></div>
            </div>
            <div class="schedule-fact">
              <span><i class="bi bi-clock"></i></span>
              <div><small>Khung giờ</small><strong>@TimeRangeText(s)</strong></div>
            </div>
            <div class="schedule-fact">
              <span><i class="bi bi-display"></i></span>
              <div><small>Thiết bị</small><strong>@s.Devices.Count thiết bị</strong></div>
            </div>
            <div class="schedule-fact">
              <span><i class="bi bi-play-btn"></i></span>
              <div><small>Nội dung</small><strong>@s.Items.Count video</strong></div>
            </div>
          </div>

          <div class="schedule-live-preview">
            <div class="schedule-preview-group">
              <span class="schedule-preview-label">Thiết bị</span>
              <div class="schedule-preview-chips">
                @foreach (var device in visibleDevices)
                {
                  <span class="schedule-preview-chip">@device.Device.DeviceCode</span>
                }
                @if (remainingDevices > 0)
                {
                  <span class="schedule-preview-chip muted">+@remainingDevices</span>
                }
              </div>
            </div>

            <div class="schedule-preview-group">
              <span class="schedule-preview-label">Video</span>
              <div class="schedule-preview-chips">
                @foreach (var item in visibleItems)
                {
                  <span class="schedule-preview-chip">@item.Media.FileName</span>
                }
                @if (remainingItems > 0)
                {
                  <span class="schedule-preview-chip muted">+@remainingItems</span>
                }
              </div>
            </div>
          </div>
        </div>
      </article>

      <div class="modal-overlay u-hidden" id="scheduleDetail-@s.Id">
        <div class="modal modal-wide detail-modal schedule-detail-modal">
          <div class="detail-modal-header">
            <div class="detail-title-group">
              <span class="detail-title-icon schedule"><i class="bi bi-calendar2-week"></i></span>
              <div>
                <div class="modal-title">@s.Name</div>
                <p class="detail-subtitle">Quản lý lịch phát, thiết bị và thứ tự video.</p>
              </div>
            </div>
            <button class="modal-close" type="button" onclick="closeScheduleDetail(@s.Id)" aria-label="Đóng"><i class="bi bi-x-lg"></i></button>
          </div>
          <div class="modal-body">
            <div class="detail-summary-grid">
              <section class="detail-panel">
                <div class="detail-panel-head">
                  <span><i class="bi bi-info-circle"></i></span>
                  <h3>Thông tin phát</h3>
                </div>
                <div class="detail-fact-list">
                  <div class="detail-fact"><span>Trạng thái</span><strong class="detail-status @(s.IsActive ? "active" : "muted")">@(s.IsActive ? "Đang hoạt động" : "Đã tắt")</strong></div>
                  <div class="detail-fact"><span>Kiểu phát</span><strong>@(s.IsImmediate ? "Phát ngay" : "Theo lịch")</strong></div>
                  <div class="detail-fact"><span>Khung ngày</span><strong>@DateRangeText(s)</strong></div>
                  <div class="detail-fact"><span>Khung giờ</span><strong>@TimeRangeText(s)</strong></div>
                </div>
              </section>
              <section class="detail-panel">
                <div class="detail-panel-head">
                  <span><i class="bi bi-display"></i></span>
                  <h3>Thiết bị nhận lịch</h3>
                </div>
                <div class="detail-chip-row">
                  @foreach (var d in s.Devices.OrderBy(x => x.Device.DeviceCode))
                  {
                    <span class="detail-chip"><i class="bi bi-pc-display"></i>@d.Device.DeviceCode</span>
                  }
                </div>
              </section>
            </div>

            <section class="detail-panel detail-panel-wide u-mt-1">
              <div class="detail-panel-head split">
                <div>
                  <span><i class="bi bi-collection-play"></i></span>
                  <div>
                    <h3>Video phát</h3>
                    <p>Thêm, xóa, đổi thứ tự. Thiết bị đồng bộ sau 5 giây.</p>
                  </div>
                </div>
              </div>

              <div class="schedule-item-toolbar">
                <form method="post" action="/portal/schedules/add-item" class="schedule-add-item-form">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="scheduleId" value="@s.Id" />
                  <select class="form-input" name="mediaId" required>
                    <option value="">Chọn video để thêm</option>
                    @foreach (var media in medias)
                    {
                      <option value="@media.Id">@media.FileName</option>
                    }
                  </select>
                  <button type="submit" class="btn btn-primary fx-btn"><i class="bi bi-plus-lg"></i>Thêm</button>
                </form>
              </div>

              <div class="table-wrapper detail-table-wrap u-mt-075">
                <table class="table schedule-item-table">
                  <thead>
                    <tr class="fx-list-row"><th>Thứ tự</th><th>Tên video</th><th>Dung lượng</th><th>Thao tác</th></tr>
                  </thead>
                  <tbody>
                    @foreach (var item in s.Items.OrderBy(i => i.OrderIndex))
                    {
                      <tr data-item-id="@item.Id" data-schedule-id="@s.Id" class="schedule-item-row" draggable="true">
                        <td class="schedule-order-cell">
                          <span class="schedule-item-handle">☰</span>
                          <span>#@(item.OrderIndex + 1)</span>
                        </td>
                        <td><span class="detail-media-name">@item.Media.FileName</span></td>
                        <td><span class="detail-size-chip">@(item.Media.FileSize / 1024 / 1024) MB</span></td>
                        <td>
                          <div class="flex gap-2">
                            <form method="post" action="/portal/schedules/remove-item" onsubmit="return confirm('Xóa video khỏi schedule?')">
                              @Html.AntiForgeryToken()
                              <input type="hidden" name="scheduleItemId" value="@item.Id" />
                              <button type="submit" class="detail-danger-btn"><i class="bi bi-trash"></i>Xóa</button>
                            </form>
                          </div>
                        </td>
                      </tr>
                    }
                  </tbody>
                </table>
              </div>
            </section>
          </div>
        </div>
      </div>
    }
  </div>
}

<style>
  .schedule-mode-grid { display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap:1rem; }
  .schedule-mode-card { display:flex; align-items:center; gap:1rem; text-align:left; border:1px solid var(--border); cursor:pointer; transition: border-color .15s, transform .15s; }
  .schedule-mode-card:hover { border-color: var(--primary); transform: translateY(-1px); }
  .schedule-mode-card strong { display:block; color: var(--foreground); font-size: 1rem; }
  .schedule-mode-card small { display:block; color: var(--muted-foreground); margin-top:.25rem; }
  .schedule-mode-icon { width:42px; height:42px; border-radius: 999px; display:flex; align-items:center; justify-content:center; background: rgba(37, 99, 235, .1); color: var(--primary); font-weight:700; }
  .schedule-create-panel { border:1px solid #dbe7f5; border-radius: 8px; background:#fff; box-shadow: 0 16px 40px rgba(15, 23, 42, .08); overflow:hidden; }
  .schedule-builder-head { display:flex; align-items:center; justify-content:space-between; gap:1rem; padding: 1rem 1.1rem; border-bottom:1px solid #e3ebf7; background:#f8fbff; }
  .schedule-builder-title { display:flex; align-items:center; gap:.8rem; min-width:0; }
  .schedule-builder-title h3 { margin:0; font-size:1rem; line-height:1.3; color:#0f172a; }
  .schedule-builder-title p { margin:.2rem 0 0; color:#64748b; font-size:.82rem; }
  .schedule-builder-icon { width:38px; height:38px; border-radius:8px; background:#2563eb; color:#fff; display:flex; align-items:center; justify-content:center; flex:0 0 auto; }
  .schedule-builder-close { width:34px; height:34px; border-radius:8px; }
  .schedule-create-form { display:block; }
  .schedule-builder-grid { display:grid; grid-template-columns: minmax(0, 1.55fr) minmax(280px, .75fr); gap:1rem; padding:1rem; align-items:start; }
  .schedule-builder-main { display:grid; gap:1rem; min-width:0; }
  .schedule-builder-side { display:grid; gap:1rem; min-width:0; }
  .schedule-builder-section { border:1px solid #dbe7f5; border-radius:8px; background:#fff; padding:1rem; min-width:0; }
  .schedule-section-head { display:flex; align-items:center; gap:.55rem; margin-bottom:.85rem; }
  .schedule-section-head > span, .schedule-section-head > div > span { width:28px; height:28px; border-radius:8px; display:inline-flex; align-items:center; justify-content:center; background:#eff6ff; color:#2563eb; flex:0 0 auto; }
  .schedule-section-head h4 { margin:0; font-size:.95rem; color:#0f172a; }
  .schedule-section-head-split { justify-content:space-between; gap:.75rem; flex-wrap:wrap; }
  .schedule-section-head-split > div { display:flex; align-items:center; gap:.55rem; min-width:0; }
  .schedule-name-field { margin-bottom:1rem; }
  .schedule-time-layout { display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap:1rem; }
  .schedule-fieldset { border:1px solid #e3ebf7; border-radius:8px; background:#f8fbff; padding:.85rem; min-width:0; }
  .schedule-fieldset-head { display:flex; align-items:flex-start; justify-content:space-between; gap:.75rem; margin-bottom:.75rem; flex-wrap:wrap; }
  .schedule-fieldset-head strong { display:inline-flex; align-items:center; gap:.4rem; color:#0f172a; font-size:.86rem; }
  .schedule-preset-row { display:flex; gap:.35rem; flex-wrap:wrap; }
  .schedule-preset { border:1px solid #dbe7f5; background:#fff; color:#1e3a8a; border-radius:8px; padding:.34rem .55rem; font-size:.76rem; font-weight:700; cursor:pointer; line-height:1.1; }
